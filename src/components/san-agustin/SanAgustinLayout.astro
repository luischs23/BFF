---
import Layout from "../../layouts/Layout.astro";
import SanAgustinSidebar from "./SanAgustinSidebar.astro";
import type { CategoryTree } from "./SanAgustinSidebar.astro";

interface Props {
	title: string;
	currentSlug: string;
	tree: CategoryTree[];
}

const { title, currentSlug, tree } = Astro.props;
---

<Layout title={`${title} — San Agustín`}>
	<style>
		.agustin-sidebar {
			width: 280px;
			flex-shrink: 0;
		}
		@media (max-width: 767px) {
			.agustin-sidebar {
				position: fixed;
				top: 0;
				left: -280px;
				height: 100%;
				z-index: 55;
				transition: left 0.3s ease;
			}
			.agustin-sidebar.open {
				left: 0;
			}
		}
	</style>

	<div class="flex h-screen relative bg-amber-50/70 dark:bg-gray-900 transition-colors duration-300">
		<!-- Overlay móvil -->
		<div id="sidebarOverlay" class="fixed inset-0 bg-black/50 z-40 hidden md:hidden"></div>

		<!-- Botón menú móvil -->
		<button
			id="menuToggle"
			class="md:hidden fixed top-4 right-4 z-[60] bg-amber-700/90 text-white p-2.5 rounded-full shadow-lg hover:bg-amber-800 transition backdrop-blur-sm"
			aria-label="Abrir menú"
		>
			<svg id="menuIcon" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
			</svg>
			<svg id="closeIcon" class="h-5 w-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
			</svg>
		</button>

		<!-- Sidebar -->
		<SanAgustinSidebar tree={tree} currentSlug={currentSlug} />

		<!-- Contenido principal -->
		<main class="flex-1 overflow-y-auto bg-amber-50 dark:bg-gray-950 transition-colors duration-300">
			<div class="max-w-3xl mx-auto px-4 py-8 md:py-10">
				<slot />
			</div>
		</main>
	</div>
</Layout>

<style is:global>
	.agustin-content p {
		margin: 0.9rem 0;
		line-height: 1.85;
		color: #292524;
		text-align: justify;
		hyphens: auto;
	}
	:is(.dark) .agustin-content p { color: #e7e5e4; }

	.agustin-content h2 {
		font-size: 1.1rem;
		font-weight: 700;
		color: #92400e;
		margin-top: 2rem;
		margin-bottom: 0.75rem;
	}
	:is(.dark) .agustin-content h2 { color: #fbbf24; }

	.agustin-content h3 {
		font-size: 1rem;
		font-weight: 600;
		color: #78350f;
		margin-top: 1.5rem;
		margin-bottom: 0.5rem;
	}
	:is(.dark) .agustin-content h3 { color: #fcd34d; }

	.agustin-content blockquote {
		border-left: 3px solid #d97706;
		padding-left: 1rem;
		margin: 1.5rem 0;
		font-style: italic;
		color: #57534e;
	}
	:is(.dark) .agustin-content blockquote { color: #a8a29e; border-left-color: #92400e; }
</style>

<script>
	function initSidebar() {
		const menuToggle = document.getElementById('menuToggle');
		const sidebar = document.getElementById('agustinsidebar');
		const overlay = document.getElementById('sidebarOverlay');
		const menuIcon = document.getElementById('menuIcon');
		const closeIcon = document.getElementById('closeIcon');

		function openSidebar() {
			sidebar?.classList.add('open');
			overlay?.classList.remove('hidden');
			menuIcon?.classList.add('hidden');
			closeIcon?.classList.remove('hidden');
		}
		function closeSidebar() {
			sidebar?.classList.remove('open');
			overlay?.classList.add('hidden');
			menuIcon?.classList.remove('hidden');
			closeIcon?.classList.add('hidden');
		}

		menuToggle?.addEventListener('click', () => {
			sidebar?.classList.contains('open') ? closeSidebar() : openSidebar();
		});
		overlay?.addEventListener('click', closeSidebar);
	}

	document.addEventListener('astro:page-load', initSidebar);
	initSidebar();
</script>
