---
export type SeccionEntry = {
	id: string;
	title: string;
	numero?: number;
	description?: string;
};

interface Props {
	catequesis: SeccionEntry[];
	defensaDeLaFe: SeccionEntry[];
	currentId: string;
}

const { catequesis, defensaDeLaFe, currentId } = Astro.props;
---

<aside
	id="apologeticaSidebar"
	class="fixed md:relative w-[260px] h-[calc(100%-3.5rem)] md:h-full top-[3.5rem] md:top-0 bg-stone-50 dark:bg-gray-900 border-r border-stone-200 dark:border-gray-700 overflow-y-auto flex-shrink-0 flex flex-col z-50 transform -translate-x-full md:translate-x-0 transition-all duration-300 ease-in-out"
>
	<!-- Cabecera -->
	<div class="px-4 py-5 border-b border-stone-200 dark:border-gray-700">
		<a
			href="/"
			class="flex items-center gap-2 text-emerald-600 dark:text-emerald-400 hover:text-emerald-700 dark:hover:text-emerald-300 transition text-sm mb-3"
		>
			<svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
			</svg>
			Inicio
		</a>
		<a href="/apologetica" class="block">
			<h1 class="text-base font-bold text-gray-800 dark:text-gray-100 leading-tight">Apologética</h1>
			<p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Defensa de la Fe</p>
		</a>
	</div>

	<!-- Navegación -->
	<nav class="flex-1 py-3 px-2 overflow-y-auto">
		<a
			href="/apologetica"
			class={`flex items-center gap-2 px-3 py-2 rounded-lg text-sm transition mb-1 ${
				!currentId
					? "bg-emerald-100 dark:bg-emerald-700/40 text-emerald-900 dark:text-emerald-100 font-semibold"
					: "text-gray-700 dark:text-gray-200 hover:bg-stone-200 dark:hover:bg-gray-700"
			}`}
		>
			<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
			</svg>
			Inicio
		</a>

		{catequesis.length > 0 && (
			<>
				<p class="text-[10px] font-bold uppercase tracking-widest text-emerald-600 dark:text-emerald-500 px-3 py-2 mt-2">
					Catequesis
				</p>
				<div class="space-y-0.5">
					{catequesis.map((e) => (
						<a
							href={`/apologetica/${e.id}`}
							data-astro-prefetch="hover"
							class={`flex items-center gap-2 px-3 py-2 rounded-lg text-sm transition ${
								e.id === currentId
									? "bg-emerald-100 dark:bg-emerald-700/40 text-emerald-900 dark:text-emerald-100 font-semibold"
									: "text-gray-700 dark:text-gray-200 hover:bg-stone-200 dark:hover:bg-gray-700"
							}`}
						>
							{e.numero !== undefined && (
								<span class={`flex-shrink-0 w-5 h-5 rounded-full text-[10px] font-bold flex items-center justify-center ${
									e.id === currentId
										? "bg-emerald-200/60 text-emerald-800 dark:bg-emerald-600/40 dark:text-emerald-100"
										: "bg-emerald-100 dark:bg-emerald-900/40 text-emerald-600 dark:text-emerald-400"
								}`}>
									{e.numero}
								</span>
							)}
							<span class="truncate text-xs">{e.title}</span>
						</a>
					))}
				</div>
			</>
		)}

		{defensaDeLaFe.length > 0 && (
			<>
				<p class="text-[10px] font-bold uppercase tracking-widest text-emerald-600 dark:text-emerald-500 px-3 py-2 mt-3">
					Defensa de la Fe
				</p>
				<div class="space-y-0.5">
					{defensaDeLaFe.map((e) => (
						<a
							href={`/apologetica/${e.id}`}
							data-astro-prefetch="hover"
							class={`flex items-center gap-2 px-3 py-2 rounded-lg text-sm transition ${
								e.id === currentId
									? "bg-emerald-100 dark:bg-emerald-700/40 text-emerald-900 dark:text-emerald-100 font-semibold"
									: "text-gray-700 dark:text-gray-200 hover:bg-stone-200 dark:hover:bg-gray-700"
							}`}
						>
							{e.numero !== undefined && (
								<span class={`flex-shrink-0 w-5 h-5 rounded-full text-[10px] font-bold flex items-center justify-center ${
									e.id === currentId
										? "bg-emerald-200/60 text-emerald-800 dark:bg-emerald-600/40 dark:text-emerald-100"
										: "bg-emerald-100 dark:bg-emerald-900/40 text-emerald-600 dark:text-emerald-400"
								}`}>
									{e.numero}
								</span>
							)}
							<span class="truncate text-xs">{e.title}</span>
						</a>
					))}
				</div>
			</>
		)}
	</nav>

	<!-- Pie -->
	<div class="px-4 py-3 border-t border-stone-200 dark:border-gray-700">
		<p class="text-xs text-gray-400 dark:text-gray-500 text-center italic leading-relaxed">
			«Dad razón de vuestra esperanza»<br/>
			<span class="not-italic">1 Pe 3,15</span>
		</p>
	</div>
</aside>
