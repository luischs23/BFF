---
import Layout from "../../layouts/Layout.astro";
import SumaTeologicaSidebar from "./SumaTeologicaSidebar.astro";
import type { PartTree } from "./SumaTeologicaSidebar.astro";

interface Props {
	title: string;
	currentSlug: string;
	tree: PartTree[];
	cuestionNum?: number;
}

const { title, currentSlug, tree, cuestionNum } = Astro.props;
const isWelcomePage = !currentSlug;
---

<Layout title={`${title} — Suma Teológica`}>
	<div
		id="sumaContainer"
		class="flex h-screen relative bg-stone-50 dark:bg-gray-950 transition-colors duration-300"
		data-welcome={isWelcomePage ? 'true' : undefined}
	>
		<!-- Overlay móvil -->
		<div id="sidebarOverlay" class="fixed inset-0 bg-black/50 z-40 hidden md:hidden"></div>

		{isWelcomePage ? (
			<button
				id="menuToggle"
				class="md:hidden fixed top-4 right-4 z-[60] bg-red-700/90 text-white p-2.5 rounded-full shadow-lg hover:bg-red-800 transition backdrop-blur-sm"
				aria-label="Abrir menú"
			>
				<svg id="menuIcon" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
				</svg>
				<svg id="closeIcon" class="h-5 w-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
				</svg>
			</button>
		) : (
			<header
				id="mobileHeader"
				class="md:hidden fixed top-0 left-0 right-0 z-[60] bg-white dark:bg-gray-950 border-b border-gray-200 dark:border-gray-800 px-4 py-3 flex items-center justify-between"
			>
				<div class="w-8"></div>
				<h1 class="text-sm font-semibold text-gray-800 dark:text-gray-200 truncate mx-3 flex-1 text-center">
					{cuestionNum ? <span class="text-red-500 dark:text-red-400 mr-1">C.{cuestionNum}</span> : null}{title}
				</h1>
				<button
					id="menuToggle"
					class="p-1.5 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
					aria-label="Abrir menú"
				>
					<svg id="menuIcon" class="h-5 w-5 text-gray-700 dark:text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
					</svg>
					<svg id="closeIcon" class="h-5 w-5 hidden text-gray-700 dark:text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
					</svg>
				</button>
			</header>
		)}

		<!-- Sidebar -->
		<SumaTeologicaSidebar tree={tree} currentSlug={currentSlug} />

		<!-- Contenido principal -->
		<main class="flex-1 overflow-y-auto bg-stone-50 dark:bg-gray-950 transition-colors duration-300">
			<div class="max-w-3xl mx-auto px-0 py-0 md:px-4 md:py-10">
				<slot />
			</div>
		</main>
	</div>
</Layout>

<style is:global>
	#sumaContainer:not([data-welcome]) > main {
		padding-top: 3.5rem;
	}
	@media (min-width: 768px) {
		#sumaContainer:not([data-welcome]) > main {
			padding-top: 0;
		}
	}
	
	.suma-content p {
		margin: 0.9rem 0;
		line-height: 1.9;
		color: #1c1917;
		text-align: justify;
		hyphens: auto;
	}
	:is(.dark) .suma-content p { color: #e7e5e4; }

	.suma-content h2 {
		font-size: 1rem;
		font-weight: 700;
		color: #991b1b;
		text-align: center;
		margin-top: 2.5rem;
		margin-bottom: 1rem;
		padding-top: 1.25rem;
		border-top: 1px solid #e7e5e4;
	}
	:is(.dark) .suma-content h2 { color: #fca5a5; border-top-color: #374151; }

	/* Numerales de objeciones y respuestas */
	.suma-content .suma-n {
		font-weight: 700;
		color: #991b1b;
		margin-right: 0.3em;
		font-size: 0.85em;
	}
	:is(.dark) .suma-content .suma-n { color: #fca5a5; }
	.suma-content .suma-n a {
		color: inherit;
		text-decoration: none;
	}
	.suma-content .suma-n a:hover { text-decoration: underline; }

	.suma-content h3 {
		font-size: 0.95rem;
		font-weight: 600;
		color: #7f1d1d;
		margin-top: 1.5rem;
		margin-bottom: 0.5rem;
	}
	:is(.dark) .suma-content h3 { color: #fecaca; }

	.suma-content blockquote {
		border-left: 3px solid #dc2626;
		padding-left: 1rem;
		margin: 1.5rem 0;
		font-style: italic;
		color: #57534e;
	}
	:is(.dark) .suma-content blockquote { color: #a8a29e; border-left-color: #7f1d1d; }
</style>

<script>
	import { initMobileMenu } from "../../scripts/biblia/mobileMenu";
	import { initDarkMode } from "../../scripts/biblia/darkMode";

	function initSuma() {
		initMobileMenu();
		initDarkMode();
	}

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', initSuma);
	} else {
		initSuma();
	}
	document.addEventListener('astro:page-load', initSuma);
</script>
