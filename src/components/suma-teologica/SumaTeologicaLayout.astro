---
import Layout from "../../layouts/Layout.astro";
import SumaTeologicaSidebar from "./SumaTeologicaSidebar.astro";
import SumaTeologicaMobileHeader from "./SumaTeologicaMobileHeader.astro";
import SumaGlobalSearchDialog from "./SumaGlobalSearchDialog.astro";
import type { PartTree } from "./SumaTeologicaSidebar.astro";

interface Props {
	title: string;
	currentSlug: string;
	tree: PartTree[];
	cuestionNum?: number;
}

const { title, currentSlug, tree, cuestionNum } = Astro.props;
const isWelcomePage = !currentSlug;
---

<Layout title={`${title} — Suma Teológica`}>
	<div
		id="sumaContainer"
		class="flex h-screen relative bg-stone-50 dark:bg-gray-950 transition-colors duration-300"
		data-welcome={isWelcomePage ? 'true' : undefined}
	>
		<!-- Overlay móvil -->
		<div id="sidebarOverlay" class="fixed inset-0 bg-black/50 z-40 hidden md:hidden"></div>

		{isWelcomePage ? (
			<button
				id="menuToggle"
				class="md:hidden fixed top-4 right-4 z-[60] bg-red-700/90 text-white p-2.5 rounded-full shadow-lg hover:bg-red-800 transition backdrop-blur-sm"
				aria-label="Abrir menú"
			>
				<svg id="menuIcon" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
				</svg>
				<svg id="closeIcon" class="h-5 w-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
				</svg>
			</button>
		) : (
			<SumaTeologicaMobileHeader title={title} cuestionNum={cuestionNum} />
		)}

		<!-- Sidebar -->
		<SumaTeologicaSidebar tree={tree} currentSlug={currentSlug} />

		<!-- Contenido principal -->
		<main class="flex-1 overflow-y-auto bg-stone-50 dark:bg-gray-950 transition-colors duration-300">
			<div class="max-w-3xl mx-auto px-0 py-0 md:px-4 md:pb-10">
				<slot />
			</div>
		</main>
	</div>

	<SumaGlobalSearchDialog />
</Layout>

<style is:global>
	/* Fuente serif para todo el contenido, igual que la Biblia */
	.suma-content {
		font-family: "Times New Roman", Times, serif;
	}

	.suma-content p {
		margin: 0.75rem 0;
		line-height: 1.7;
		color: #1c1917;
		text-align: justify;
		hyphens: auto;
		font-size: 1rem;
		text-indent: 1.5em;
	}
	:is(.dark) .suma-content p { color: #e7e5e4; }

	/* Sin sangría tras encabezados ni en blockquotes (tipografía de libro) */
	.suma-content h2 + p,
	.suma-content h3 + p,
	.suma-content blockquote p,
	.suma-content p:first-child {
		text-indent: 0;
	}

	.suma-content h2 {
		font-size: 1rem;
		font-weight: 700;
		color: #991b1b;
		text-align: center;
		margin-top: 2.5rem;
		margin-bottom: 1rem;
		padding-top: 1.25rem;
		border-top: 1px solid #e7e5e4;
	}
	:is(.dark) .suma-content h2 { color: #fca5a5; border-top-color: #374151; }

	/* Numerales de objeciones y respuestas */
	.suma-content .suma-n {
		font-weight: 700;
		color: #991b1b;
		margin-right: 0.3em;
		font-size: 0.85em;
	}
	:is(.dark) .suma-content .suma-n { color: #fca5a5; }
	.suma-content .suma-n a {
		color: inherit;
		text-decoration: none;
	}
	.suma-content .suma-n a:hover { text-decoration: underline; }

	.suma-content h3 {
		font-size: 0.95rem;
		font-weight: 600;
		color: #7f1d1d;
		margin-top: 1.5rem;
		margin-bottom: 0.5rem;
	}
	:is(.dark) .suma-content h3 { color: #fecaca; }

	.suma-content blockquote {
		border-left: 3px solid #dc2626;
		padding-left: 1rem;
		margin: 1.5rem 0;
		font-style: italic;
		color: #57534e;
	}
	:is(.dark) .suma-content blockquote { color: #a8a29e; border-left-color: #7f1d1d; }
</style>

<script>
	import { initMobileMenu } from "../../scripts/biblia/mobileMenu";
	import { initDarkMode } from "../../scripts/biblia/darkMode";

	function syncSidebarToHeader() {
		const header = document.getElementById('mobileHeader');
		const sidebar = document.getElementById('sidebar');
		const main = document.querySelector<HTMLElement>('#sumaContainer main');
		const container = document.getElementById('sumaContainer');
		if (!header || !sidebar || !main) return;
		const isWelcome = container?.hasAttribute('data-welcome');
		if (isWelcome) return;

		const h = header.offsetHeight;
		// Solo aplica en móvil; en desktop el sidebar es relative y main no necesita ajuste JS
		if (window.innerWidth < 768) {
			sidebar.style.top = `${h}px`;
			sidebar.style.height = `calc(100vh - ${h}px)`;
			main.style.paddingTop = `${h}px`;
		} else {
			sidebar.style.top = '';
			sidebar.style.height = '';
			main.style.paddingTop = `${h}px`;
		}
	}

	function initSuma() {
		initMobileMenu();
		initDarkMode();
		syncSidebarToHeader();
	}

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', initSuma);
	} else {
		initSuma();
	}
	document.addEventListener('astro:page-load', initSuma);
	window.addEventListener('resize', syncSidebarToHeader);
</script>
