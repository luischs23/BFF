---
import { Search, X, BookOpen } from "lucide-astro";
---

<div
  id="sumaSearchOverlay"
  class="hidden fixed inset-0 bg-black/60 z-[200] items-start justify-center p-4 pt-14 md:pt-10"
  role="dialog"
  aria-modal="true"
  aria-label="Búsqueda en la Suma Teológica"
>
  <div class="w-full max-w-2xl bg-white dark:bg-gray-900 rounded-xl shadow-2xl flex flex-col max-h-[88vh] overflow-hidden">

    <!-- Header del modal -->
    <div class="flex items-center gap-3 px-4 py-3 border-b border-gray-200 dark:border-gray-700 flex-shrink-0">
      <Search class="h-5 w-5 text-red-600 dark:text-red-400 flex-shrink-0" />
      <input
        type="text"
        id="sumaSearchInput"
        placeholder="Buscar en la Suma Teológica..."
        autocomplete="off"
        class="flex-1 bg-transparent text-gray-900 dark:text-gray-100 placeholder-gray-400 dark:placeholder-gray-500 text-base outline-none"
      />
      <button
        id="sumaSearchClose"
        class="p-1.5 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 text-gray-500 dark:text-gray-400 transition-colors flex-shrink-0"
        aria-label="Cerrar búsqueda"
      >
        <X class="h-5 w-5" />
      </button>
    </div>

    <!-- Barra de estado -->
    <div id="ssStatus" class="hidden px-4 py-2 text-xs text-gray-500 dark:text-gray-400 border-b border-gray-100 dark:border-gray-800 flex-shrink-0"></div>

    <!-- Resultados -->
    <div id="ssResults" class="overflow-y-auto flex-1 p-3 space-y-2">
      <div id="ssInitial" class="flex flex-col items-center justify-center py-16 text-center">
        <BookOpen class="h-12 w-12 text-gray-300 dark:text-gray-600 mb-3" />
        <p class="text-gray-500 dark:text-gray-400 text-sm">Escribe al menos 3 letras para buscar</p>
        <p class="text-gray-400 dark:text-gray-500 text-xs mt-1">en todas las cuestiones de la Suma Teológica</p>
      </div>
      <div id="ssLoading" class="hidden flex flex-col items-center justify-center py-16">
        <div class="w-8 h-8 border-2 border-red-500 border-t-transparent rounded-full animate-spin mb-3"></div>
        <p class="text-gray-500 dark:text-gray-400 text-sm">Buscando...</p>
      </div>
      <div id="ssEmpty" class="hidden flex flex-col items-center justify-center py-16 text-center">
        <Search class="h-10 w-10 text-gray-300 dark:text-gray-600 mb-3" />
        <p class="text-gray-600 dark:text-gray-400 text-sm font-medium">Sin resultados</p>
        <p class="text-gray-400 dark:text-gray-500 text-xs mt-1">Intenta con otras palabras</p>
      </div>
      <div id="ssResultsList" class="hidden space-y-2"></div>
    </div>
  </div>
</div>

<style>
  #ssResults::-webkit-scrollbar { width: 5px; }
  #ssResults::-webkit-scrollbar-track { background: transparent; }
  #ssResults::-webkit-scrollbar-thumb { background: #d6d3d1; border-radius: 3px; }
  .dark #ssResults::-webkit-scrollbar-thumb { background: #4b5563; }
  .ss-match {
    background-color: #fee2e2;
    border-radius: 2px;
    padding: 0 1px;
  }
  .dark .ss-match {
    background-color: #7f1d1d;
    color: #fecaca;
  }
</style>

<script>
  function initSumaGlobalSearch() {
    const overlay = document.getElementById('sumaSearchOverlay');
    const input = document.getElementById('sumaSearchInput') as HTMLInputElement;
    const closeBtn = document.getElementById('sumaSearchClose');
    const statusEl = document.getElementById('ssStatus');
    const initialEl = document.getElementById('ssInitial');
    const loadingEl = document.getElementById('ssLoading');
    const emptyEl = document.getElementById('ssEmpty');
    const listEl = document.getElementById('ssResultsList');

    if (!overlay || overlay.hasAttribute('data-ss-init')) return;
    overlay.setAttribute('data-ss-init', 'true');

    function openDialog() {
      overlay!.classList.remove('hidden');
      overlay!.classList.add('flex');
      document.body.style.overflow = 'hidden';
      setTimeout(() => input?.focus(), 50);
    }

    function closeDialog() {
      overlay!.classList.add('hidden');
      overlay!.classList.remove('flex');
      document.body.style.overflow = '';
      if (input) input.value = '';
      showState('initial');
      if (statusEl) { statusEl.textContent = ''; statusEl.classList.add('hidden'); }
      if (listEl) listEl.innerHTML = '';
      lastQuery = '';
    }

    function showState(state: 'initial' | 'loading' | 'empty' | 'results') {
      initialEl?.classList.toggle('hidden', state !== 'initial');
      loadingEl?.classList.toggle('hidden', state !== 'loading');
      emptyEl?.classList.toggle('hidden', state !== 'empty');
      listEl?.classList.toggle('hidden', state !== 'results');
    }

    function escapeHtml(str: string): string {
      return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    }

    function highlightText(text: string, query: string): string {
      if (!query) return escapeHtml(text);
      const norm = (t: string) =>
        t.normalize('NFD').replace(/[\u0300-\u036f]/g, '').replace(/[,;:.!?¡¿'"«»""'']/g, '').toLowerCase();
      const normIdx = norm(text).indexOf(norm(query));
      if (normIdx === -1) return escapeHtml(text);
      const punc = /[,;:.!?¡¿'"«»""'']/;
      const normQueryLen = norm(query).length;
      let ni = 0;
      let origStart = -1, origEnd = text.length;
      for (let i = 0; i < text.length; i++) {
        const nc = text[i].normalize('NFD').replace(/[\u0300-\u036f]/g, '');
        const contributes = nc.length > 0 && !punc.test(nc);
        if (contributes) {
          if (origStart === -1 && ni === normIdx) origStart = i;
          if (ni === normIdx + normQueryLen) { origEnd = i; break; }
          ni++;
        }
      }
      if (origStart === -1) return escapeHtml(text);
      return (
        escapeHtml(text.slice(0, origStart)) +
        `<mark class="ss-match">${escapeHtml(text.slice(origStart, origEnd))}</mark>` +
        escapeHtml(text.slice(origEnd))
      );
    }

    let searchTimeout: ReturnType<typeof setTimeout>;
    let lastQuery = '';

    async function performSearch(query: string) {
      if (query === lastQuery) return;
      lastQuery = query;

      if (!query || query.length < 3) {
        showState('initial');
        if (statusEl) { statusEl.textContent = ''; statusEl.classList.add('hidden'); }
        return;
      }

      showState('loading');
      if (statusEl) statusEl.classList.add('hidden');

      try {
        const res = await fetch(`/api/suma-global-search?q=${encodeURIComponent(query)}`);
        const data = await res.json();
        if (query !== lastQuery) return;

        const { results, total } = data;

        if (!results || results.length === 0) {
          showState('empty');
          return;
        }

        if (statusEl) {
          statusEl.textContent = total >= 100
            ? 'Más de 100 resultados (mostrando los primeros 100)'
            : `${total} resultado${total !== 1 ? 's' : ''} encontrado${total !== 1 ? 's' : ''}`;
          statusEl.classList.remove('hidden');
        }

        if (listEl) {
          listEl.innerHTML = results.map((r: {
            cuestionTitle: string;
            cuestionNum: number | undefined;
            slug: string;
            artNum: number | null;
            artTitle: string;
            snippet: string;
          }) => {
            const hash = r.artNum !== null ? `#art-${r.artNum}` : '';
            const href = `/suma-teologica/${r.slug}${hash}`;
            const artLabel = r.artNum !== null
              ? `<span class="text-xs text-red-500 dark:text-red-400 font-medium">Artículo ${r.artNum}</span>`
              : `<span class="text-xs text-gray-400 dark:text-gray-500">Introducción</span>`;
            return `
              <a href="${href}" class="ss-card block p-3 rounded-lg border border-gray-200 dark:border-gray-700 hover:border-red-400 dark:hover:border-red-700 hover:bg-red-50 dark:hover:bg-red-950/20 transition-all">
                <div class="flex items-start justify-between gap-2 mb-1">
                  <span class="font-semibold text-gray-800 dark:text-gray-200 text-sm leading-tight">
                    ${r.cuestionNum !== undefined ? `<span class="text-red-600 dark:text-red-400 mr-1">C.${r.cuestionNum}</span>` : ''}${escapeHtml(r.cuestionTitle)}
                  </span>
                  ${artLabel}
                </div>
                ${r.artNum !== null && r.artTitle ? `<p class="text-xs text-gray-500 dark:text-gray-400 mb-1 truncate">${escapeHtml(r.artTitle)}</p>` : ''}
                <p class="text-sm text-gray-700 dark:text-gray-300 leading-relaxed">${highlightText(r.snippet, query)}</p>
              </a>
            `;
          }).join('');
        }

        showState('results');

        listEl?.querySelectorAll('.ss-card').forEach(card => {
          card.addEventListener('click', () => closeDialog());
        });

      } catch {
        showState('empty');
      }
    }

    input?.addEventListener('input', () => {
      clearTimeout(searchTimeout);
      searchTimeout = setTimeout(() => performSearch(input.value.trim()), 400);
    });

    closeBtn?.addEventListener('click', closeDialog);
    overlay?.addEventListener('click', (e) => { if (e.target === overlay) closeDialog(); });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !overlay!.classList.contains('hidden')) closeDialog();
    });

    (window as any).openSumaGlobalSearch = openDialog;
  }

  document.addEventListener('DOMContentLoaded', initSumaGlobalSearch);
  document.addEventListener('astro:page-load', initSumaGlobalSearch);
</script>
