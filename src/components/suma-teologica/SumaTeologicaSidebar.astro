---
const isDev = import.meta.env.DEV;
export type TreeNode = {
	slug: string;
	title: string;
	cuestion?: number;
	children: TreeNode[];
};

export type PartTree = {
	key: string;
	label: string;
	nodes: TreeNode[];
};

interface Props {
	tree: PartTree[];
	currentSlug: string;
}

const { tree, currentSlug } = Astro.props;

function containsSlug(node: TreeNode, slug: string): boolean {
	if (node.slug === slug) return true;
	return node.children.some(child => containsSlug(child, slug));
}
---

<aside id="sidebar" class="fixed md:relative w-[288px] h-[calc(100%-4rem)] md:h-full top-16 md:top-0 bg-stone-50 dark:bg-gray-900 border-r border-stone-200 dark:border-gray-700 overflow-y-auto flex-shrink-0 flex flex-col z-50 transform -translate-x-full md:translate-x-0 transition-all duration-300 ease-in-out">
	<!-- Cabecera -->
	<div class="px-4 py-5 border-b border-stone-200 dark:border-gray-700">
		<div class="flex items-center justify-between mb-3">
			<a href="/" class="flex items-center gap-2 text-red-700 dark:text-red-400 hover:text-red-800 transition text-sm">
				<svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
				</svg>
				Inicio
			</a>
			<a href="/suma-teologica" class="flex items-center gap-1.5 text-xs text-gray-400 dark:text-gray-500 hover:text-red-600 dark:hover:text-red-400 transition" title="Portada de la Suma Teológica">
				<svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
				</svg>
				Portada
			</a>
		</div>
		<a href="/suma-teologica" class="block">
			<h1 class="text-base font-bold text-gray-800 dark:text-gray-100 leading-tight">Suma Teológica</h1>
			<p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Santo Tomás de Aquino</p>
		</a>
	</div>

	<!-- Botón dev: fix blank lines -->
	{isDev && (
		<div class="px-4 pb-3">
			<button
				id="sumaFixBlankLinesBtn"
				class="w-full flex items-center justify-center gap-1.5 px-3 py-1.5 text-[10px] font-semibold uppercase tracking-wider rounded border border-dashed border-orange-400 text-orange-600 dark:text-orange-400 hover:bg-orange-50 dark:hover:bg-orange-950 transition-colors"
				title="Solo visible en desarrollo"
			>
				<svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
					<path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
				</svg>
				<span id="sumaFixLabel">Fix separación numerales</span>
			</button>
		</div>
	)}

	<!-- Árbol de navegación -->
	<nav class="flex-1 py-3 px-2 overflow-y-auto">
		{tree.map(parte => (
			<div class="mb-1">
				<p class="px-3 py-2 text-[10px] font-bold uppercase tracking-widest text-red-600 dark:text-red-500">
					{parte.label}
				</p>

				<div class="space-y-0.5">
					{parte.nodes.map(node => (
						<div>
							{node.children.length > 0 ? (
								<details open class="group/node">
									<summary class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-[11px] text-gray-500 dark:text-gray-400 font-semibold uppercase tracking-wide cursor-pointer select-none hover:bg-stone-200 dark:hover:bg-gray-800 list-none">
										<svg class="h-2.5 w-2.5 flex-shrink-0 transition-transform group-open/node:rotate-90" fill="none" viewBox="0 0 24 24" stroke="currentColor">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
										</svg>
										{node.title}
									</summary>
									<div class="ml-3 mt-0.5 space-y-0.5">
										{node.children.map(child => (
											<div>
												{child.children.length > 0 ? (
													<details open={containsSlug(child, currentSlug)} class="group/child">
														<summary class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-[11px] text-gray-400 dark:text-gray-500 font-medium cursor-pointer select-none hover:bg-stone-200 dark:hover:bg-gray-800 list-none">
															<svg class="h-2 w-2 flex-shrink-0 transition-transform group-open/child:rotate-90" fill="none" viewBox="0 0 24 24" stroke="currentColor">
																<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
															</svg>
															{child.title}
														</summary>
														<div class="ml-3 mt-0.5 space-y-0.5">
															{child.children.map(leaf => (
																<a
																	href={`/suma-teologica/${leaf.slug}`}
																	data-astro-prefetch="hover"
																	class={`block px-3 py-1 rounded-lg text-xs transition truncate ${
																		leaf.slug === currentSlug
																			? "bg-red-100 dark:bg-red-900/30 text-red-800 dark:text-red-200 font-semibold"
																			: "text-gray-600 dark:text-gray-400 hover:bg-stone-200 dark:hover:bg-gray-800"
																	}`}
																>
																	{leaf.cuestion !== undefined && (
																		<span class="text-[10px] text-gray-400 dark:text-gray-500 mr-1 font-mono">C.{leaf.cuestion}</span>
																		)}
																	{leaf.title}
																</a>
															))}
														</div>
													</details>
												) : child.slug ? (
													<a
														href={`/suma-teologica/${child.slug}`}
														data-astro-prefetch="hover"
														class={`block px-3 py-1 rounded-lg text-xs transition truncate ${
															child.slug === currentSlug
																? "bg-red-100 dark:bg-red-900/30 text-red-800 dark:text-red-200 font-semibold"
																: "text-gray-600 dark:text-gray-400 hover:bg-stone-200 dark:hover:bg-gray-800"
														}`}
													>
														{child.cuestion !== undefined && (
															<span class="text-[10px] text-gray-400 dark:text-gray-500 mr-1 font-mono">C.{child.cuestion}</span>
															)}
														{child.title}
													</a>
												) : null}
											</div>
										))}
									</div>
								</details>
							) : node.slug ? (
								<a
									href={`/suma-teologica/${node.slug}`}
									data-astro-prefetch="hover"
									class={`block px-3 py-1.5 rounded-lg text-xs transition truncate ${
										node.slug === currentSlug
											? "bg-red-100 dark:bg-red-900/30 text-red-800 dark:text-red-200 font-semibold"
											: "text-gray-600 dark:text-gray-400 hover:bg-stone-200 dark:hover:bg-gray-800"
									}`}
								>
									{node.title}
								</a>
							) : null}
						</div>
					))}
				</div>
			</div>
		))}
	</nav>

	<!-- Pie -->
	<div class="px-4 py-3 border-t border-stone-200 dark:border-gray-700">
		<p class="text-xs text-gray-400 dark:text-gray-500 text-center">
			Santo Tomás de Aquino<br/>1225 – 1274
		</p>
	</div>
</aside>

<script>
	function initSumaFixBtn() {
		const btn = document.getElementById('sumaFixBlankLinesBtn');
		const label = document.getElementById('sumaFixLabel');
		if (!btn || btn.hasAttribute('data-fix-init')) return;
		btn.setAttribute('data-fix-init', 'true');

		btn.addEventListener('click', async () => {
			if (label) label.textContent = 'Buscando archivos…';
			btn.setAttribute('disabled', 'true');
			try {
				// Obtener todos los slugs de suma desde el árbol del sidebar
				const links = Array.from(document.querySelectorAll<HTMLAnchorElement>('#sidebar a[href^="/suma-teologica/"]'));
				const slugs = links.map(a => a.getAttribute('href')!.replace('/suma-teologica/', '')).filter(Boolean);
				if (label) label.textContent = `Procesando ${slugs.length} archivos…`;
				const res = await fetch('/api/format-suma', {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify({ slugs }),
				});
				const data = await res.json();
				if (data.ok) {
					const changed = data.results.filter((r: any) => r.changed).length;
					if (label) label.textContent = `✓ ${changed} archivo(s) corregidos`;
				} else {
					if (label) label.textContent = 'Error';
				}
			} catch {
				if (label) label.textContent = 'Error de red';
			} finally {
				btn.removeAttribute('disabled');
				setTimeout(() => { if (label) label.textContent = 'Fix separación numerales'; }, 4000);
			}
		});
	}

	document.addEventListener('DOMContentLoaded', initSumaFixBtn);
	document.addEventListener('astro:page-load', initSumaFixBtn);
</script>
