---
export type TreeNode = {
	slug: string;
	title: string;
	children: TreeNode[];
};

export type PartTree = {
	key: string;
	label: string;
	nodes: TreeNode[];
};

interface Props {
	tree: PartTree[];
	currentSlug: string;
}

const { tree, currentSlug } = Astro.props;
const isDev = import.meta.env.DEV;

function containsSlug(node: TreeNode, slug: string): boolean {
	if (node.slug === slug) return true;
	return node.children.some(child => containsSlug(child, slug));
}
---

<aside id="sidebar" class="fixed md:relative w-[288px] h-[calc(100%-3.5rem)] md:h-full top-[3.5rem] md:top-0 bg-stone-50 dark:bg-gray-900 border-r border-stone-200 dark:border-gray-700 overflow-y-auto flex-shrink-0 flex flex-col z-50 transform -translate-x-full md:translate-x-0 transition-all duration-300 ease-in-out">
	<!-- Cabecera -->
	<div class="px-4 py-5 border-b border-stone-200 dark:border-gray-700">
		<a href="/" class="flex items-center gap-2 text-red-700 dark:text-red-400 hover:text-red-800 transition text-sm mb-3">
			<svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
			</svg>
			Inicio
		</a>
		<a href="/suma-teologica" class="block">
			<h1 class="text-base font-bold text-gray-800 dark:text-gray-100 leading-tight">Suma Teológica</h1>
			<p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Santo Tomás de Aquino</p>
		</a>
	</div>

	<!-- Árbol de navegación -->
	<nav class="flex-1 py-3 px-2 overflow-y-auto">
		{tree.map(parte => (
			<div class="mb-1">
				<!-- Etiqueta de parte (siempre visible) -->
				<p class="px-3 py-2 text-[10px] font-bold uppercase tracking-widest text-red-600 dark:text-red-500">
					{parte.label}
				</p>

				<div class="space-y-0.5">
					{parte.nodes.map(node => (
						<div>
							{node.children.length > 0 ? (
								/* Sección con hijos: siempre abierta, colapsable */
								<details open class="group/node">
									<summary class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-[11px] text-gray-500 dark:text-gray-400 font-semibold uppercase tracking-wide cursor-pointer select-none hover:bg-stone-200 dark:hover:bg-gray-800 list-none">
										<svg class="h-2.5 w-2.5 flex-shrink-0 transition-transform group-open/node:rotate-90" fill="none" viewBox="0 0 24 24" stroke="currentColor">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
										</svg>
										{node.title}
									</summary>
									<div class="ml-3 mt-0.5 space-y-0.5">
										{node.children.map(child => (
											<div>
												{child.children.length > 0 ? (
													/* Sub-sección con hijos: cerrada por defecto, abre si hay slug activo */
													<details open={containsSlug(child, currentSlug)} class="group/child">
														<summary class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-[11px] text-gray-400 dark:text-gray-500 font-medium cursor-pointer select-none hover:bg-stone-200 dark:hover:bg-gray-800 list-none">
															<svg class="h-2 w-2 flex-shrink-0 transition-transform group-open/child:rotate-90" fill="none" viewBox="0 0 24 24" stroke="currentColor">
																<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
															</svg>
															{child.title}
														</summary>
														<div class="ml-3 mt-0.5 space-y-0.5">
															{child.children.map(leaf => (
																<div class="flex items-center gap-1">
																	<a
																		href={`/suma-teologica/${leaf.slug}`}
																		data-astro-prefetch="hover"
																		class={`flex-1 min-w-0 px-3 py-1 rounded-lg text-xs transition truncate ${
																			leaf.slug === currentSlug
																				? "bg-red-100 dark:bg-red-900/30 text-red-800 dark:text-red-200 font-semibold"
																				: "text-gray-600 dark:text-gray-400 hover:bg-stone-200 dark:hover:bg-gray-800"
																		}`}
																	>
																		{leaf.title}
																	</a>
																	{isDev && (
																		<button
																			class="format-btn shrink-0 px-1.5 py-0.5 rounded text-[10px] font-bold text-red-400 dark:text-red-600 hover:bg-red-100 dark:hover:bg-red-900/30 hover:text-red-700 dark:hover:text-red-400 transition-colors opacity-40 hover:opacity-100"
																			data-slug={leaf.slug}
																			title={`Formatear: ${leaf.title}`}
																		>
																			F
																		</button>
																	)}
																</div>
															))}
														</div>
													</details>
												) : child.slug ? (
													/* Hoja directa dentro de una sección */
													<div class="flex items-center gap-1">
														<a
															href={`/suma-teologica/${child.slug}`}
															data-astro-prefetch="hover"
															class={`flex-1 min-w-0 px-3 py-1 rounded-lg text-xs transition truncate ${
																child.slug === currentSlug
																	? "bg-red-100 dark:bg-red-900/30 text-red-800 dark:text-red-200 font-semibold"
																	: "text-gray-600 dark:text-gray-400 hover:bg-stone-200 dark:hover:bg-gray-800"
															}`}
														>
															{child.title}
														</a>
														{isDev && (
															<button
																class="format-btn shrink-0 px-1.5 py-0.5 rounded text-[10px] font-bold text-red-400 dark:text-red-600 hover:bg-red-100 dark:hover:bg-red-900/30 hover:text-red-700 dark:hover:text-red-400 transition-colors opacity-40 hover:opacity-100"
																data-slug={child.slug}
																title={`Formatear: ${child.title}`}
															>
																F
															</button>
														)}
													</div>
												) : null}
											</div>
										))}
									</div>
								</details>
							) : node.slug ? (
								/* Hoja directa en la parte (sin carpeta) */
								<div class="flex items-center gap-1">
									<a
										href={`/suma-teologica/${node.slug}`}
										data-astro-prefetch="hover"
										class={`flex-1 min-w-0 px-3 py-1.5 rounded-lg text-xs transition truncate ${
											node.slug === currentSlug
												? "bg-red-100 dark:bg-red-900/30 text-red-800 dark:text-red-200 font-semibold"
												: "text-gray-600 dark:text-gray-400 hover:bg-stone-200 dark:hover:bg-gray-800"
										}`}
									>
										{node.title}
									</a>
									{isDev && (
										<button
											class="format-btn shrink-0 px-1.5 py-0.5 rounded text-[10px] font-bold text-red-400 dark:text-red-600 hover:bg-red-100 dark:hover:bg-red-900/30 hover:text-red-700 dark:hover:text-red-400 transition-colors opacity-40 hover:opacity-100"
											data-slug={node.slug}
											title={`Formatear: ${node.title}`}
										>
											F
										</button>
									)}
								</div>
							) : null}
						</div>
					))}
				</div>
			</div>
		))}
	</nav>

	<!-- Pie -->
	<div class="px-4 py-3 border-t border-stone-200 dark:border-gray-700">
		<p class="text-xs text-gray-400 dark:text-gray-500 text-center">
			Santo Tomás de Aquino<br/>1225 – 1274
		</p>
	</div>
</aside>

{isDev && (
	<script is:inline>
		function initFormatSuma() {
			document.querySelectorAll('.format-btn').forEach(btn => {
				if (btn.dataset.initDone) return;
				btn.dataset.initDone = 'true';

				btn.addEventListener('click', async (e) => {
					e.preventDefault();
					e.stopPropagation();
					const slug = btn.dataset.slug;
					if (!slug) return;
					const original = btn.textContent;
					btn.textContent = '…';
					btn.setAttribute('disabled', '');
					try {
						const res = await fetch('/api/format-suma', {
							method: 'POST',
							headers: { 'Content-Type': 'application/json' },
							body: JSON.stringify({ slug }),
						});
						const data = await res.json();
						if (data.ok) {
							btn.textContent = '✓';
							// Astro HMR detecta el cambio de archivo automáticamente
							setTimeout(() => { btn.textContent = original; btn.removeAttribute('disabled'); }, 2000);
						} else {
							alert('Error: ' + data.error);
							btn.textContent = original;
							btn.removeAttribute('disabled');
						}
					} catch (e) {
						alert('Error de red: ' + e);
						btn.textContent = original;
						btn.removeAttribute('disabled');
					}
				});
			});
		}

		document.addEventListener('DOMContentLoaded', initFormatSuma);
		document.addEventListener('astro:page-load', initFormatSuma);
	</script>
)}
