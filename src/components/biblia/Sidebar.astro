---
import { Search, AArrowUp, ArrowLeft } from "lucide-astro";
import type { EstructuraBiblia } from "../../lib/biblia/types";

interface Props {
	estructura: EstructuraBiblia;
	currentSlug: string;
}

const { estructura, currentSlug } = Astro.props;

// Construir lista plana de slugs para identificar libros adyacentes
const allSlugs: string[] = [];
for (const testamento of Object.values(estructura)) {
	for (const seccion of Object.values(testamento.secciones)) {
		for (const libro of seccion.libros) {
			if (!libro.data.isIntro && !libro.slug.includes('-comentarios') && !libro.slug.includes('-paralelos')) {
				allSlugs.push(libro.slug);
			}
		}
	}
}
const currentIndex = allSlugs.indexOf(currentSlug);
const adjacentSlugs = new Set([
	allSlugs[currentIndex - 1],
	allSlugs[currentIndex + 1],
].filter(Boolean));
---

<aside
	id="sidebar"
	class="fixed md:relative w-72 h-full bg-white dark:bg-gray-950 border-r border-gray-200 dark:border-gray-800 overflow-y-auto flex-shrink-0 z-50 transform -translate-x-full md:translate-x-0 transition-all duration-300 ease-in-out"
>
	<div class="p-4 pt-16 md:pt-4">
		<div class="flex items-center justify-between mb-4">
			<a href="/" class="text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-200 hover:underline text-sm transition-colors">&larr; Inicio</a>
			<div class="flex items-center gap-2">
			<!-- Botón volver al lugar de lectura (oculto por defecto) -->
			<div id="backToReadingWrapper" class="hidden relative">
				<button
					id="backToReadingBtn"
					class="p-2 rounded-lg bg-indigo-100 dark:bg-indigo-900 hover:bg-indigo-200 dark:hover:bg-indigo-800 transition-colors"
					aria-label="Volver al lugar de lectura"
					title="Volver al lugar de lectura"
				>
					<ArrowLeft class="w-5 h-5 text-indigo-600 dark:text-indigo-400" />
				</button>
				<button
					id="backToReadingDismiss"
					class="absolute -top-1.5 -right-1.5 w-4 h-4 bg-gray-400 dark:bg-gray-600 hover:bg-gray-600 dark:hover:bg-gray-400 text-white rounded-full flex items-center justify-center leading-none text-[10px]"
					aria-label="Cerrar"
					title="No mostrar"
				>✕</button>
			</div>
			<button
				id="fontSizeToggle"
				class="p-2 rounded-lg bg-gray-100 dark:bg-gray-800 hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors"
				aria-label="Cambiar tamaño de texto"
				title="Tamaño de texto"
			>
				<AArrowUp class="w-5 h-5 text-gray-600 dark:text-gray-400" />
			</button>
			<button
				id="darkModeToggle"
				class="p-2 rounded-lg bg-gray-100 dark:bg-gray-800 hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors"
				aria-label="Cambiar tema"
			>
				<!-- Sol (modo claro) -->
				<svg id="sunIcon" class="w-5 h-5 text-gray-600 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
				</svg>
				<!-- Luna (modo oscuro) -->
				<svg id="moonIcon" class="w-5 h-5 text-gray-500 dark:text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
				</svg>
			</button>
			</div>
		</div>
		<div class="flex items-center justify-between mb-1">
			<h2 class="text-lg font-bold text-gray-900 dark:text-gray-100">Sagrada Biblia</h2>
			<button
				id="sidebarGlobalSearch"
				class="p-1.5 rounded-lg text-gray-500 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800 hover:text-amber-700 dark:hover:text-amber-400 transition-colors"
				aria-label="Buscar en toda la Biblia"
				title="Buscar en toda la Biblia"
			>
				<Search class="h-4 w-4" />
			</button>
		</div>
		<a
			href="/biblia"
			data-astro-prefetch="hover"
			class="no-underline inline-flex items-center gap-1.5 mb-4 text-[11px] font-medium text-amber-700 dark:text-amber-500 hover:text-amber-900 dark:hover:text-amber-300 transition-colors"
		>
			<svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
				<path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
			</svg>
			Inicio Biblia
		</a>

		{Object.entries(estructura).map(([testamentoKey, testamento]) => (
			<div class="mb-6">
				<h3 class="font-bold text-gray-800 dark:text-gray-200 mb-2 text-sm uppercase tracking-wide">
					{testamento.titulo}
				</h3>

				{Object.entries(testamento.secciones).map(([seccionKey, seccion]) => (
					seccion.libros.length > 0 && (
						<div class="mb-3">
							<button
								class="section-toggle w-full flex items-center justify-between text-[11px] font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400 mb-1 px-2 py-1.5 bg-gray-50 dark:bg-gray-900 hover:bg-gray-100 dark:hover:bg-gray-800 rounded border-l-2 border-gray-300 dark:border-gray-600 transition-all"
								data-section={`${testamentoKey}-${seccionKey}`}
							>
								<span>{seccion.titulo}</span>
								<svg class="toggle-icon w-3.5 h-3.5 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" />
								</svg>
							</button>
							<ul class="section-content space-y-1" data-section={`${testamentoKey}-${seccionKey}`}>
								{seccion.libros
									.filter(libro => !libro.data.isIntro && !libro.slug.includes('-comentarios') && !libro.slug.includes('-paralelos'))
									.map(libro => (
										<li>
											<a
												href={`/biblia/${libro.slug}`}
												data-astro-prefetch={adjacentSlugs.has(libro.slug) ? "hover" : undefined}
												class:list={[
													"block px-3 py-1.5 text-sm rounded transition",
													libro.slug === currentSlug
														? "bg-gray-200 dark:bg-gray-700 text-gray-900 dark:text-gray-100 font-semibold"
														: "text-gray-600 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800 hover:text-gray-900 dark:hover:text-gray-200"
												]}
											>
												{libro.data.title}
											</a>
										</li>
									))}
							</ul>
						</div>
					)
				))}
			</div>
		))}
	</div>
</aside>

<script>
	function initSidebarBookLinks() {
		document.querySelectorAll<HTMLAnchorElement>('#sidebar a[href^="/biblia/"]').forEach(link => {
			if (link.hasAttribute('data-nav-init')) return;
			link.setAttribute('data-nav-init', 'true');
			link.addEventListener('click', () => {
				// Quitar estado activo previo
				document.querySelectorAll('#sidebar a[data-loading]').forEach(el => {
					el.removeAttribute('data-loading');
					(el as HTMLElement).style.opacity = '';
				});
				link.setAttribute('data-loading', 'true');
				link.style.opacity = '0.5';
				// Limpiar al terminar la navegación
				document.addEventListener('astro:page-load', () => {
					link.removeAttribute('data-loading');
					link.style.opacity = '';
				}, { once: true });
			});
		});
	}
	document.addEventListener('DOMContentLoaded', initSidebarBookLinks);
	document.addEventListener('astro:page-load', initSidebarBookLinks);

	function initSidebarSearch() {
		const btn = document.getElementById('sidebarGlobalSearch');
		btn?.addEventListener('click', () => {
			(window as any).openGlobalSearch?.();
		});
	}
	document.addEventListener('DOMContentLoaded', initSidebarSearch);
	document.addEventListener('astro:page-load', initSidebarSearch);

	// Control de tamaño de texto
	let fontSizeInitialized = false;

	function initFontSize() {
		// Aplicar tamaño guardado siempre (incluso en re-navegaciones SPA)
		const savedSize = localStorage.getItem('bibleFontSize') || 'medium';
		const fontSizes: Record<string, string> = {
			small: 'text-sm', medium: 'text-base', large: 'text-lg', xlarge: 'text-xl'
		};
		Object.values(fontSizes).forEach(cls => document.body.classList.remove(cls));
		document.body.classList.add(fontSizes[savedSize] || fontSizes.medium);

		if (fontSizeInitialized && document.getElementById('fontSizePanel')) return;
		fontSizeInitialized = true;

		const fontSizeToggle = document.getElementById('fontSizeToggle');

		// Crear el panel dinámicamente
		let fontSizePanel = document.getElementById('fontSizePanel');
		if (!fontSizePanel) {
			fontSizePanel = document.createElement('div');
			fontSizePanel.id = 'fontSizePanel';
			fontSizePanel.setAttribute('style', 'position: fixed; background: white; border-radius: 8px; box-shadow: 0 10px 25px rgba(0,0,0,0.2); border: 1px solid #d1d5db; padding: 12px; min-width: 160px; z-index: 9999; display: none;');
			fontSizePanel.innerHTML = `
				<p style="font-size: 12px; color: #6b7280; margin-bottom: 8px; font-weight: 500;">Tamaño de texto</p>
				<div style="display: flex; flex-direction: column; gap: 4px;">
					<button class="font-size-option" data-size="small" style="text-align: left; padding: 6px 12px; border-radius: 4px; border: none; background: transparent; cursor: pointer; color: #374151; font-size: 14px;">
						<span style="font-size: 12px; font-weight: bold; margin-right: 8px;">A</span> Pequeño
					</button>
					<button class="font-size-option" data-size="medium" style="text-align: left; padding: 6px 12px; border-radius: 4px; border: none; background: transparent; cursor: pointer; color: #374151;">
						<span style="font-size: 16px; font-weight: bold; margin-right: 8px;">A</span> Mediano
					</button>
					<button class="font-size-option" data-size="large" style="text-align: left; padding: 6px 12px; border-radius: 4px; border: none; background: transparent; cursor: pointer; color: #374151;">
						<span style="font-size: 18px; font-weight: bold; margin-right: 8px;">A</span> Grande
					</button>
					<button class="font-size-option" data-size="xlarge" style="text-align: left; padding: 6px 12px; border-radius: 4px; border: none; background: transparent; cursor: pointer; color: #374151;">
						<span style="font-size: 20px; font-weight: bold; margin-right: 8px;">A</span> Muy grande
					</button>
				</div>
			`;
			document.body.appendChild(fontSizePanel);
		}

		const fontSizeOptions = fontSizePanel.querySelectorAll('.font-size-option');
		updateActiveOption(savedSize);

		let panelOpen = false;

		if (fontSizeToggle && !fontSizeToggle.hasAttribute('data-initialized')) {
			fontSizeToggle.setAttribute('data-initialized', 'true');

			fontSizeToggle.addEventListener('click', (e) => {
				e.stopPropagation();
				e.preventDefault();
				panelOpen = !panelOpen;
				if (panelOpen) {
					const rect = fontSizeToggle.getBoundingClientRect();
					fontSizePanel!.style.top = `${rect.bottom + 8}px`;
					fontSizePanel!.style.left = `${rect.left}px`;
					fontSizePanel!.style.display = 'block';
				} else {
					fontSizePanel!.style.display = 'none';
				}
			});

			document.addEventListener('click', (e) => {
				const target = e.target as Node;
				if (panelOpen && fontSizePanel && !fontSizePanel.contains(target) && target !== fontSizeToggle && !fontSizeToggle.contains(target)) {
					fontSizePanel.style.display = 'none';
					panelOpen = false;
				}
			});
		}

		function getScrollAnchor(): Element | null {
			const main = document.querySelector('main');
			if (!main) return null;
			const mainRect = main.getBoundingClientRect();
			const targetY = mainRect.top + mainRect.height * 0.25;
			const candidates = document.querySelectorAll('.bible-content sup, .bible-content .chapter-marker');
			let best: Element | null = null;
			let bestDist = Infinity;
			for (const el of candidates) {
				const rect = el.getBoundingClientRect();
				if (rect.top < mainRect.top) continue;
				const dist = Math.abs(rect.top - targetY);
				if (dist < bestDist) { bestDist = dist; best = el; }
			}
			return best;
		}

		fontSizeOptions.forEach(option => {
			if (!option.hasAttribute('data-initialized')) {
				option.setAttribute('data-initialized', 'true');
				option.addEventListener('click', (e) => {
					e.stopPropagation();
					const size = (option as HTMLElement).dataset.size || 'medium';
					const anchor = getScrollAnchor();
					applyFontSize(size);
					updateActiveOption(size);
					localStorage.setItem('bibleFontSize', size);
					fontSizePanel!.style.display = 'none';
					panelOpen = false;
					if (anchor) requestAnimationFrame(() => anchor.scrollIntoView({ block: 'center' }));
				});
			}
		});

		function applyFontSize(size: string) {
			Object.values(fontSizes).forEach(cls => document.body.classList.remove(cls));
			document.body.classList.add(fontSizes[size] || fontSizes.medium);
		}

		function updateActiveOption(size: string) {
			fontSizeOptions.forEach(option => {
				(option as HTMLElement).style.background =
					(option as HTMLElement).dataset.size === size ? '#fde68a' : 'transparent';
			});
		}
	}

	document.addEventListener('DOMContentLoaded', initFontSize);
	document.addEventListener('astro:page-load', initFontSize);

	function initBackToReadingDismiss() {
		const dismissBtn = document.getElementById('backToReadingDismiss');
		if (!dismissBtn || dismissBtn.hasAttribute('data-initialized')) return;
		dismissBtn.setAttribute('data-initialized', 'true');
		dismissBtn.addEventListener('click', (e) => {
			e.stopPropagation();
			sessionStorage.removeItem('bibleReturnAnchor');
			document.getElementById('backToReadingWrapper')?.classList.add('hidden');
		});
	}
	document.addEventListener('DOMContentLoaded', initBackToReadingDismiss);
	document.addEventListener('astro:page-load', initBackToReadingDismiss);
</script>
