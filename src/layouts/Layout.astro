---
import "../styles/global.css"; 
import { ClientRouter } from "astro:transitions";

interface Props{
	title:string;
}
const {title} = Astro.props;
---
<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="theme-color" content="#0f172a" />
		<meta name="description" content="Lee la Biblia en cualquier momento y lugar" />
		<link rel="icon" type="image/x-icon" href="/icons/favicon.ico" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="apple-touch-icon" href="/icons/apple-touch-icon.png" />
		<title>{title}</title>
		<ClientRouter/>
		<script is:inline>
			(function () {
				var timer = null;
				var done = false;

				// Siempre re-query para no cachear referencia obsoleta
				function getBar() {
					return document.getElementById('navLoadingBar');
				}

				function startLoading() {
					done = false;
					var b = getBar();
					if (!b) return;
					b.style.transition = 'none';
					b.style.width = '0%';
					b.style.opacity = '1';
					b.offsetWidth; // forzar reflow
					b.style.transition = 'width 10s cubic-bezier(0.05,0.05,0,1)';
					b.style.width = '80%';
					if (timer) clearTimeout(timer);
					timer = setTimeout(function () { if (!done) finishLoading(); }, 15000);
				}

				function finishLoading() {
					done = true;
					if (timer) { clearTimeout(timer); timer = null; }
					var b = getBar();
					if (!b) return;
					b.style.transition = 'width 0.15s ease';
					b.style.width = '100%';
					setTimeout(function () {
						b.style.transition = 'opacity 0.3s ease';
						b.style.opacity = '0';
						setTimeout(function () {
							b.style.transition = 'none';
							b.style.width = '0%';
						}, 350);
					}, 150);
				}

				document.addEventListener('astro:before-preparation', startLoading);
				document.addEventListener('astro:page-load', finishLoading);
			})();
		</script>
		<script is:inline>
			// Aplicar tamaño de fuente guardado en todas las páginas
			(function() {
				var sizes = ['text-sm', 'text-base', 'text-lg', 'text-xl'];
				var saved = localStorage.getItem('bibleFontSize') || 'medium';
				var map = { small: 'text-sm', medium: 'text-base', large: 'text-lg', xlarge: 'text-xl' };
				var cls = map[saved] || 'text-base';
				sizes.forEach(function(s) { document.body.classList.remove(s); });
				document.body.classList.add(cls);
			})();
			document.addEventListener('astro:after-swap', function() {
				var sizes = ['text-sm', 'text-base', 'text-lg', 'text-xl'];
				var saved = localStorage.getItem('bibleFontSize') || 'medium';
				var map = { small: 'text-sm', medium: 'text-base', large: 'text-lg', xlarge: 'text-xl' };
				var cls = map[saved] || 'text-base';
				sizes.forEach(function(s) { document.body.classList.remove(s); });
				document.body.classList.add(cls);
			});
		</script>
		<script is:inline>
			function __applyDark(doc) {
				var val = localStorage.getItem('biblia-dark-mode');
				var dark = val === 'true' || (val === null && window.matchMedia('(prefers-color-scheme: dark)').matches);
				if (dark) doc.documentElement.classList.add('dark');
				else doc.documentElement.classList.remove('dark');
			}
			// Aplicar en carga inicial
			__applyDark(document);

			// Antes del swap: aplicar dark al documento entrante y deshabilitar transitions
			document.addEventListener('astro:before-swap', function(e) {
				__applyDark(e.newDocument);
				e.newDocument.documentElement.classList.add('no-transition');
			});
			// Después del swap: re-confirmar y re-habilitar transitions en el siguiente frame
			document.addEventListener('astro:after-swap', function() {
				__applyDark(document);
				requestAnimationFrame(function() {
					document.documentElement.classList.remove('no-transition');
				});
			});
		</script>
	</head>
	<body class="bg-amber-50/70 dark:bg-gray-900 min-h-screen transition-colors duration-300">
		<!-- Barra de carga de navegación (transition:persist para sobrevivir swaps SPA) -->
		<div id="navLoadingBar" transition:persist style="position:fixed;top:0;left:0;height:3px;width:0;background:linear-gradient(90deg,#b45309,#f59e0b,#fbbf24);z-index:99999;opacity:0;pointer-events:none;"></div>
		<slot />
	</body>
</html>

