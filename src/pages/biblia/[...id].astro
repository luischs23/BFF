---
import { getCollection, render } from "astro:content";
import BibliaLayout from "../../components/biblia/BibliaLayout.astro";
import { organizarLibrosPorSeccion } from "../../lib/biblia/organizarLibros";

export const prerender = true;

export async function getStaticPaths() {
	const libros = await getCollection("sagrada-biblia");

	// Agregar ruta base /biblia (sin parámetros)
	const paths = [
		{ params: { id: undefined }, props: { book: null } },
		...libros.map((book) => ({
			params: { id: book.id },
			props: { book }
		}))
	];

	return paths;
}

const { book } = Astro.props;

// Obtener todos los libros para el sidebar
const libros = await getCollection('sagrada-biblia');

// Organizar libros por sección
const estructura = organizarLibrosPorSeccion(libros);

// Si no hay libro seleccionado, mostrar página de bienvenida
const isWelcomePage = !book;
const title = book ? book.data.title : "Sagrada Biblia";
const slug = book ? book.id : "";
const Content = book ? (await render(book)).Content : null;

const FALLBACK_COLOR = 'bg-gray-500';
const FALLBACK_LABEL = 'text-gray-400';

const DOT_AT: Record<string, string> = {
	'01-pentateuco': 'bg-blue-500', '02-libros-historicos': 'bg-amber-500',
	'03-lirica': 'bg-violet-500', '04-libros-sapienciales': 'bg-emerald-500',
	'05-libros-profeticos': 'bg-rose-500',
};
const LABEL_AT: Record<string, string> = {
	'01-pentateuco': 'text-blue-500 dark:text-blue-400',
	'02-libros-historicos': 'text-amber-500 dark:text-amber-400',
	'03-lirica': 'text-violet-500 dark:text-violet-400',
	'04-libros-sapienciales': 'text-emerald-500 dark:text-emerald-400',
	'05-libros-profeticos': 'text-rose-500 dark:text-rose-400',
};
const DOT_NT: Record<string, string> = {
	'01-evangelios': 'bg-yellow-500', '02-hechos': 'bg-orange-500',
	'03-epistolas-pablo': 'bg-sky-500', '04-hebreos': 'bg-indigo-500',
	'05-epistolas-catolicas': 'bg-teal-500', '06-apocalipsis': 'bg-red-500',
};
const LABEL_NT: Record<string, string> = {
	'01-evangelios': 'text-yellow-500 dark:text-yellow-400',
	'02-hechos': 'text-orange-500 dark:text-orange-400',
	'03-epistolas-pablo': 'text-sky-500 dark:text-sky-400',
	'04-hebreos': 'text-indigo-500 dark:text-indigo-400',
	'05-epistolas-catolicas': 'text-teal-500 dark:text-teal-400',
	'06-apocalipsis': 'text-red-500 dark:text-red-400',
};

function buildRows(secciones: any, dotMap: any, labelMap: any) {
	return (Object.entries(secciones) as [string, any][]).map(([key, sec]) => ({
		key,
		titulo: sec.titulo as string,
		dot: (dotMap[key] as string) ?? FALLBACK_COLOR,
		label: (labelMap[key] as string) ?? FALLBACK_LABEL,
		libros: (sec.libros as any[])
			.filter((l: any) => !l.data.isIntro && !l.id.includes('-comentarios') && !l.id.includes('-paralelos'))
			.map((l: any) => ({ slug: l.id as string, title: l.data.title as string })),
	})).filter(r => r.libros.length > 0);
}

const rowsAT = buildRows(estructura['antiguo-testamento'].secciones, DOT_AT, LABEL_AT);
const rowsNT = buildRows(estructura['nuevo-testamento'].secciones, DOT_NT, LABEL_NT);
---

<BibliaLayout title={title} slug={slug} estructura={estructura} isWelcomePage={isWelcomePage}>
	{Content ? (
		<Content />
	) : (
		<div class="welcome-content max-w-2xl mx-auto pb-8 pt-0 px-5">

			<div class="text-center mb-6">
				<div class="inline-flex items-center justify-center w-20 h-20 rounded-full overflow-hidden shadow-lg">
					<img src="/Biblia.jpg" alt="Sagrada Biblia" class="w-full h-full object-cover" />
				</div>
			</div>

			<!-- Card versículo del día -->
			<p class="text-[11px] font-semibold uppercase tracking-[0.2em] text-gray-400/60 dark:text-gray-600 mb-3">Biblia Jerusalén</p>		

			<!-- Antiguo Testamento -->
			<div class="mb-10">
				<p class="text-[11px] font-semibold uppercase tracking-[0.2em] text-gray-400/60 dark:text-gray-600 mb-5">Antiguo Testamento</p>
				<div class="space-y-6">
					{rowsAT.map(row => (
						<div>
							<div class={`flex items-center gap-2 mb-2.5 pl-3 border-l-2 ${row.dot.replace('bg-', 'border-')}`}>
								<span class={`text-[10px] font-bold uppercase tracking-widest ${row.label}`}>{row.titulo}</span>
							</div>
							<div class="flex flex-col gap-1.5">
								{row.libros.map(libro => (
									<a
										href={`/biblia/${libro.slug}`}
										data-book-card
										data-slug={libro.slug}
										data-dot={row.dot}
										data-label={row.label}
										data-section={row.titulo}
										data-book-title={libro.title}
										data-astro-prefetch="false"
										class="no-underline flex items-center gap-3 px-4 py-3 rounded-2xl bg-white hover:bg-gray-50 dark:bg-gray-900 dark:hover:bg-gray-800 border border-gray-200 hover:border-gray-300 dark:border-white/5 dark:hover:border-white/10 transition-all duration-150 group"
									>
										<span class={`shrink-0 w-2 h-2 rounded-full ${row.dot}`}></span>
										<div class="min-w-0 flex-1">
											<span class="text-gray-700 dark:text-gray-300 text-xs font-medium truncate block">{libro.title}</span>
										</div>
										<svg class="shrink-0 w-3 h-3 text-gray-300 dark:text-gray-700 group-hover:text-gray-400 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
											<path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
										</svg>
									</a>
								))}
							</div>
						</div>
					))}
				</div>
			</div>

			<!-- Nuevo Testamento -->
			<div>
				<p class="text-[11px] font-semibold uppercase tracking-[0.2em] text-gray-400/60 dark:text-gray-600 mb-5">Nuevo Testamento</p>
				<div class="space-y-6">
					{rowsNT.map(row => (
						<div>
							<div class={`flex items-center gap-2 mb-2.5 pl-3 border-l-2 ${row.dot.replace('bg-', 'border-')}`}>
								<span class={`text-[10px] font-bold uppercase tracking-widest ${row.label}`}>{row.titulo}</span>
							</div>
							<div class="flex flex-col gap-1.5">
								{row.libros.map(libro => (
									<a
										href={`/biblia/${libro.slug}`}
										data-book-card
										data-slug={libro.slug}
										data-dot={row.dot}
										data-label={row.label}
										data-section={row.titulo}
										data-book-title={libro.title}
										data-astro-prefetch="false"
										class="no-underline flex items-center gap-3 px-4 py-3 rounded-2xl bg-white hover:bg-gray-50 dark:bg-gray-900 dark:hover:bg-gray-800 border border-gray-200 hover:border-gray-300 dark:border-white/5 dark:hover:border-white/10 transition-all duration-150 group"
									>
										<span class={`shrink-0 w-2 h-2 rounded-full ${row.dot}`}></span>
										<div class="min-w-0 flex-1">
											<span class="text-gray-700 dark:text-gray-300 text-xs font-medium truncate block">{libro.title}</span>
										</div>
										<svg class="shrink-0 w-3 h-3 text-gray-300 dark:text-gray-700 group-hover:text-gray-400 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
											<path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
										</svg>
									</a>
								))}
							</div>
						</div>
					))}
				</div>
			</div>

		</div>
	)}
<script>
function getDateSeed(): number {
  const d = new Date();
  return d.getFullYear() * 10000 + (d.getMonth() + 1) * 100 + d.getDate();
}

let verseOfDayLoaded = false;
async function initVerseOfDay() {
  const card = document.getElementById('verseOfDayCard') as HTMLAnchorElement | null;
  if (!card) return;
  const cacheKey = 'verseOfDay_' + getDateSeed();
  const cached = sessionStorage.getItem(cacheKey);
  let data: { text: string; chapter: number; verse: string; verseNum: number; slug: string; bookTitle: string } | null = null;
  if (cached) {
    try { data = JSON.parse(cached); } catch {}
  }
  if (!data) {
    try {
      const res = await fetch('/api/verse-of-day');
      if (res.ok) {
        data = await res.json();
        sessionStorage.setItem(cacheKey, JSON.stringify(data));
      }
    } catch {}
  }
  if (!data) return;
  const bookEl = document.getElementById('verseOfDayBook');
  const textEl = document.getElementById('verseOfDayText');
  const refEl = document.getElementById('verseOfDayRef');
  if (textEl) textEl.textContent = data.text;
  if (bookEl) bookEl.textContent = data.bookTitle;
  if (refEl) refEl.textContent = `${data.bookTitle} ${data.chapter},${data.verse}`;
  const bookCard = document.querySelector(`[data-book-card][data-slug="${data.slug}"]`) as HTMLElement | null;
  const dotEl = document.getElementById('verseOfDayDot');
  if (bookCard && dotEl) {
    dotEl.className = `shrink-0 w-2 h-2 rounded-full ${bookCard.dataset.dot || 'bg-amber-500'}`;
  }
  card.href = `/biblia/${data.slug}#chapter-${data.chapter}-verse-${data.verseNum}`;
}

document.addEventListener('DOMContentLoaded', () => { initVerseOfDay(); });
document.addEventListener('astro:page-load', () => { if (!verseOfDayLoaded) { verseOfDayLoaded = true; initVerseOfDay(); } });

function initBookCardFeedback() {
  document.querySelectorAll<HTMLAnchorElement>('[data-book-card]').forEach(card => {
    if (card.hasAttribute('data-nav-init')) return;
    card.setAttribute('data-nav-init', 'true');
    card.addEventListener('click', () => {
      card.style.opacity = '0.5';
      card.style.pointerEvents = 'none';
      document.addEventListener('astro:page-load', () => {
        card.style.opacity = '';
        card.style.pointerEvents = '';
      }, { once: true });
    });
  });
}
document.addEventListener('DOMContentLoaded', initBookCardFeedback);
document.addEventListener('astro:page-load', initBookCardFeedback);
</script>

</BibliaLayout>
