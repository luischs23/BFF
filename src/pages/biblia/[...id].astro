// También usamos VERSES para la card de versículo del día (tomado del pool de BV)
const VERSES_POOL = Object.entries(BV).map(([slug, arr]) => ({ slug, arr }));

function seededRand(seed: number): number {
  const x = Math.sin(seed + 1) * 10000;
  return x - Math.floor(x);
}

function getDateSeed(): number {
  const d = new Date();
  return d.getFullYear() * 10000 + (d.getMonth() + 1) * 100 + d.getDate();
}

function initVerseOfDay() {
  const card = document.getElementById('verseOfDayCard') as HTMLAnchorElement | null;
  if (!card) return;
  const dateSeed = getDateSeed();
  const poolIdx = Math.floor(seededRand(dateSeed + 42) * VERSES_POOL.length);
  const { slug, arr } = VERSES_POOL[poolIdx];
  const vIdx = Math.floor(seededRand(dateSeed + 99) * arr.length);
  const v = arr[vIdx];
  const dotEl = document.getElementById('verseOfDayDot');
  const sectionEl = document.getElementById('verseOfDaySection');
  const bookEl = document.getElementById('verseOfDayBook');
  const textEl = document.getElementById('verseOfDayText');
  const refEl = document.getElementById('verseOfDayRef');
  if (textEl) textEl.textContent = v.t;
  if (refEl) refEl.textContent = v.r;
  // find book name from a data-book-card
  const bookCard = document.querySelector(`[data-book-card][data-slug="${slug}"]`) as HTMLElement | null;
  if (bookCard && bookEl) bookEl.textContent = bookCard.dataset.bookTitle || slug.split('/').pop() || '';
  if (bookCard && sectionEl) sectionEl.textContent = bookCard.dataset.section || '';
  if (bookCard && dotEl) {
    const dot = bookCard.dataset.dot || 'bg-amber-500';
    dotEl.className = `shrink-0 w-2 h-2 rounded-full ${dot}`;
    sectionEl!.className = `text-[10px] font-semibold uppercase tracking-widest ${(bookCard.dataset.label || 'text-amber-500/80')}`;
  }
  card.href = `/biblia/${slug}#chapter-${v.c}-verse-${v.v}`;
}

function initBookCards() {
  const cards = document.querySelectorAll<HTMLElement>('[data-book-card]');
  if (!cards.length) return;
  const dateSeed = getDateSeed();
  cards.forEach((card, i) => {
    const slug = card.dataset.slug;
    if (!slug) return;
    const verses = BV[slug];
    if (!verses?.length) return;
    const idx = Math.floor(seededRand(dateSeed + i * 37 + 7) * verses.length);
    const v = verses[idx];
    const verseEl = card.querySelector('.book-verse');
    const refEl = card.querySelector('.book-ref');
    if (verseEl) verseEl.textContent = `"${v.t}"`;
    if (refEl) refEl.textContent = v.r;
    (card as HTMLAnchorElement).href = `/biblia/${slug}#chapter-${v.c}-verse-${v.v}`;
  });
}

document.addEventListener('DOMContentLoaded', () => { initBookCards(); initVerseOfDay(); });
document.addEventListener('astro:page-load', () => { initBookCards(); initVerseOfDay(); });
</script>

