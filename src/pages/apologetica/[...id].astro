---
import { getCollection, render } from "astro:content";
import ApologeticaLayout from "../../components/apologetica/ApologeticaLayout.astro";

export const prerender = true;

export async function getStaticPaths() {
	const entradas = await getCollection("apologetica");
	const paths = [
		{ params: { id: undefined }, props: { entrada: null } },
		...entradas.map((e) => ({
			params: { id: e.id },
			props: { entrada: e },
		})),
	];
	return paths;
}

const { entrada } = Astro.props;
const todasLasEntradas = await getCollection("apologetica");

const catequesis = todasLasEntradas
	.filter((e) => e.id.startsWith("catequesis/"))
	.sort((a, b) => (a.data.numero ?? 0) - (b.data.numero ?? 0))
	.map((e) => ({ id: e.id, title: e.data.title, numero: e.data.numero, description: e.data.description }));

const defensaDeLaFe = todasLasEntradas
	.filter((e) => e.id.startsWith("defensa-de-la-fe/"))
	.sort((a, b) => (a.data.numero ?? 0) - (b.data.numero ?? 0))
	.map((e) => ({ id: e.id, title: e.data.title, numero: e.data.numero, description: e.data.description }));

const title = entrada ? entrada.data.title : "Apologética";
const Content = entrada ? (await render(entrada)).Content : null;
const currentId = entrada?.id ?? "";
---

<ApologeticaLayout title={title} currentId={currentId} catequesis={catequesis} defensaDeLaFe={defensaDeLaFe}>
	{Content ? (
		<article class="apol-content bg-white dark:bg-gray-900 rounded-xl shadow-sm md:shadow-md p-6 md:p-10">
			<h1 class="text-2xl md:text-3xl font-bold text-center text-emerald-800 dark:text-emerald-300 mb-6 pb-4 border-b border-emerald-100 dark:border-emerald-900">
				{entrada!.data.title}
			</h1>
			<Content />
		</article>
	) : (
		<!-- Página de bienvenida -->
		<div class="px-4 py-8 md:py-10">
			<div class="text-center mb-10">
				<div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-emerald-100 dark:bg-emerald-900/40 mb-4 shadow-lg">
					<svg class="w-10 h-10 text-emerald-600 dark:text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
						<path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
					</svg>
				</div>
				<h1 class="text-3xl md:text-4xl font-bold text-gray-800 dark:text-gray-100 mb-3">Apologética</h1>
				<p class="text-emerald-600 dark:text-emerald-400 font-semibold text-lg mb-2">Defensa de la Fe</p>
				<p class="text-gray-600 dark:text-gray-300 max-w-xl mx-auto text-sm leading-relaxed">
					Recursos para conocer, vivir y defender la fe católica, fundamentados en la Sagrada Escritura y la Tradición de la Iglesia.
				</p>
			</div>

			<!-- Los 4 pasos de la conversión -->
			<div class="mb-10">
				<h2 class="text-xs font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest mb-5 text-center">
					Los pasos de la conversión
				</h2>
				<div class="grid sm:grid-cols-2 gap-4">
					<div class="bg-white dark:bg-gray-800 border border-emerald-200 dark:border-gray-700 rounded-xl p-5">
						<div class="flex items-center gap-3 mb-3">
							<span class="w-8 h-8 rounded-full bg-emerald-100 dark:bg-emerald-900/40 text-emerald-700 dark:text-emerald-300 text-sm font-bold flex items-center justify-center flex-shrink-0">1</span>
							<h3 class="font-bold text-gray-800 dark:text-gray-100">Conocer a Cristo</h3>
						</div>
						<p class="text-xs text-emerald-700 dark:text-emerald-400 font-semibold mb-2 uppercase tracking-wide">Encuentro personal</p>
						<p class="text-sm text-gray-600 dark:text-gray-300 leading-relaxed mb-3">La conversión comienza con un encuentro real con Jesús, no solo con ideas.</p>
						<div class="space-y-1.5 border-l-2 border-emerald-300 dark:border-emerald-700 pl-2">
							<p class="text-xs text-gray-500 dark:text-gray-400 italic">«Esta es la vida eterna: que te conozcan a ti… y a Jesucristo» — Jn 17,3</p>
							<p class="text-xs text-gray-500 dark:text-gray-400 italic">«Vengan y verán» — Jn 1,39</p>
							<p class="text-xs text-gray-500 dark:text-gray-400 italic">«Todo lo considero pérdida comparado con el conocimiento de Cristo» — Flp 3,8</p>
						</div>
					</div>
					<div class="bg-white dark:bg-gray-800 border border-emerald-200 dark:border-gray-700 rounded-xl p-5">
						<div class="flex items-center gap-3 mb-3">
							<span class="w-8 h-8 rounded-full bg-emerald-100 dark:bg-emerald-900/40 text-emerald-700 dark:text-emerald-300 text-sm font-bold flex items-center justify-center flex-shrink-0">2</span>
							<h3 class="font-bold text-gray-800 dark:text-gray-100">Dejarse transformar</h3>
						</div>
						<p class="text-xs text-emerald-700 dark:text-emerald-400 font-semibold mb-2 uppercase tracking-wide">Conversión interior</p>
						<p class="text-sm text-gray-600 dark:text-gray-300 leading-relaxed mb-3">El encuentro lleva a un cambio profundo de vida, no solo emoción.</p>
						<div class="space-y-1.5 border-l-2 border-emerald-300 dark:border-emerald-700 pl-2">
							<p class="text-xs text-gray-500 dark:text-gray-400 italic">«Transfórmense por la renovación de la mente» — Rm 12,2</p>
							<p class="text-xs text-gray-500 dark:text-gray-400 italic">«Les daré un corazón nuevo» — Ez 36,26</p>
							<p class="text-xs text-gray-500 dark:text-gray-400 italic">«El que está en Cristo es una nueva criatura» — 2 Cor 5,17</p>
						</div>
					</div>
					<div class="bg-white dark:bg-gray-800 border border-emerald-200 dark:border-gray-700 rounded-xl p-5">
						<div class="flex items-center gap-3 mb-3">
							<span class="w-8 h-8 rounded-full bg-emerald-100 dark:bg-emerald-900/40 text-emerald-700 dark:text-emerald-300 text-sm font-bold flex items-center justify-center flex-shrink-0">3</span>
							<h3 class="font-bold text-gray-800 dark:text-gray-100">Darlo a conocer</h3>
						</div>
						<p class="text-xs text-emerald-700 dark:text-emerald-400 font-semibold mb-2 uppercase tracking-wide">Misión</p>
						<p class="text-sm text-gray-600 dark:text-gray-300 leading-relaxed mb-3">Quien ha encontrado a Cristo no puede guardárselo. La fe se vuelve anuncio.</p>
						<div class="space-y-1.5 border-l-2 border-emerald-300 dark:border-emerald-700 pl-2">
							<p class="text-xs text-gray-500 dark:text-gray-400 italic">«Vayan y hagan discípulos» — Mt 28,19</p>
							<p class="text-xs text-gray-500 dark:text-gray-400 italic">«Era como fuego en mi interior… no podía contenerlo» — Jr 20,9</p>
							<p class="text-xs text-gray-500 dark:text-gray-400 italic">«No podemos dejar de hablar de lo que hemos visto y oído» — Hch 4,20</p>
						</div>
					</div>
					<div class="bg-white dark:bg-gray-800 border border-emerald-200 dark:border-gray-700 rounded-xl p-5">
						<div class="flex items-center gap-3 mb-3">
							<span class="w-8 h-8 rounded-full bg-emerald-100 dark:bg-emerald-900/40 text-emerald-700 dark:text-emerald-300 text-sm font-bold flex items-center justify-center flex-shrink-0">4</span>
							<h3 class="font-bold text-gray-800 dark:text-gray-100">Defender la fe</h3>
						</div>
						<p class="text-xs text-emerald-700 dark:text-emerald-400 font-semibold mb-2 uppercase tracking-wide">Testimonio firme</p>
						<p class="text-sm text-gray-600 dark:text-gray-300 leading-relaxed mb-3">La conversión madura lleva a perseverar y defender la fe, incluso en dificultad.</p>
						<div class="space-y-1.5 border-l-2 border-emerald-300 dark:border-emerald-700 pl-2">
							<p class="text-xs text-gray-500 dark:text-gray-400 italic">«Estad siempre preparados para dar razón de vuestra esperanza» — 1 Pe 3,15</p>
							<p class="text-xs text-gray-500 dark:text-gray-400 italic">«He peleado el buen combate, he mantenido la fe» — 2 Tim 4,7</p>
							<p class="text-xs text-gray-500 dark:text-gray-400 italic">«Al que me confiese delante de los hombres…» — Mt 10,32</p>
						</div>
					</div>
				</div>
			</div>

			<!-- Síntesis -->
			<div class="bg-emerald-50 dark:bg-emerald-900/20 border border-emerald-200 dark:border-emerald-800 rounded-xl p-6 mb-8">
				<h2 class="text-xs font-bold text-emerald-700 dark:text-emerald-300 uppercase tracking-widest mb-4 text-center">Síntesis</h2>
				<div class="flex flex-col sm:flex-row items-center justify-center gap-2 sm:gap-0 text-sm text-center">
					<span class="bg-white dark:bg-gray-800 border border-emerald-200 dark:border-emerald-700 rounded-lg px-3 py-2 text-gray-700 dark:text-gray-200 font-medium">Conocerlo<br/><span class="text-xs text-emerald-600 dark:text-emerald-400 font-normal">Encuentro</span></span>
					<span class="text-emerald-400 dark:text-emerald-600 font-bold text-lg sm:mx-2">→</span>
					<span class="bg-white dark:bg-gray-800 border border-emerald-200 dark:border-emerald-700 rounded-lg px-3 py-2 text-gray-700 dark:text-gray-200 font-medium">Transformarse<br/><span class="text-xs text-emerald-600 dark:text-emerald-400 font-normal">Conversión</span></span>
					<span class="text-emerald-400 dark:text-emerald-600 font-bold text-lg sm:mx-2">→</span>
					<span class="bg-white dark:bg-gray-800 border border-emerald-200 dark:border-emerald-700 rounded-lg px-3 py-2 text-gray-700 dark:text-gray-200 font-medium">Anunciarlo<br/><span class="text-xs text-emerald-600 dark:text-emerald-400 font-normal">Misión</span></span>
					<span class="text-emerald-400 dark:text-emerald-600 font-bold text-lg sm:mx-2">→</span>
					<span class="bg-white dark:bg-gray-800 border border-emerald-200 dark:border-emerald-700 rounded-lg px-3 py-2 text-gray-700 dark:text-gray-200 font-medium">Defenderlo<br/><span class="text-xs text-emerald-600 dark:text-emerald-400 font-normal">Fidelidad</span></span>
				</div>
			</div>

			<!-- Grid de entradas disponibles -->
			{(catequesis.length > 0 || defensaDeLaFe.length > 0) && (
				<div>
					{catequesis.length > 0 && (
						<>
							<h2 class="text-xs font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest mb-3">Catequesis</h2>
							<div class="grid sm:grid-cols-2 gap-4 mb-6">
								{catequesis.map((e) => (
									<a
										href={`/apologetica/${e.id}`}
										class="group bg-white dark:bg-gray-800 border border-emerald-200 dark:border-gray-700 rounded-xl p-5 hover:border-emerald-400 dark:hover:border-emerald-500 hover:shadow-md transition-all"
									>
										<div class="flex items-start gap-3">
											{e.numero !== undefined && (
												<span class="flex-shrink-0 w-9 h-9 rounded-full bg-emerald-100 dark:bg-emerald-900/40 text-emerald-600 dark:text-emerald-300 text-sm font-bold flex items-center justify-center group-hover:bg-emerald-200 transition-colors">
													{e.numero}
												</span>
											)}
											<div>
												<h3 class="font-bold text-gray-800 dark:text-gray-100 group-hover:text-emerald-600 dark:group-hover:text-emerald-300 transition-colors">{e.title}</h3>
												{e.description && <p class="text-xs text-gray-500 dark:text-gray-400 mt-1 leading-snug">{e.description}</p>}
											</div>
										</div>
									</a>
								))}
							</div>
						</>
					)}
					{defensaDeLaFe.length > 0 && (
						<>
							<h2 class="text-xs font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest mb-3">Defensa de la Fe</h2>
							<div class="grid sm:grid-cols-2 gap-4">
								{defensaDeLaFe.map((e) => (
									<a
										href={`/apologetica/${e.id}`}
										class="group bg-white dark:bg-gray-800 border border-emerald-200 dark:border-gray-700 rounded-xl p-5 hover:border-emerald-400 dark:hover:border-emerald-500 hover:shadow-md transition-all"
									>
										<div class="flex items-start gap-3">
											{e.numero !== undefined && (
												<span class="flex-shrink-0 w-9 h-9 rounded-full bg-emerald-100 dark:bg-emerald-900/40 text-emerald-600 dark:text-emerald-300 text-sm font-bold flex items-center justify-center group-hover:bg-emerald-200 transition-colors">
													{e.numero}
												</span>
											)}
											<div>
												<h3 class="font-bold text-gray-800 dark:text-gray-100 group-hover:text-emerald-600 dark:group-hover:text-emerald-300 transition-colors">{e.title}</h3>
												{e.description && <p class="text-xs text-gray-500 dark:text-gray-400 mt-1 leading-snug">{e.description}</p>}
											</div>
										</div>
									</a>
								))}
							</div>
						</>
					)}
				</div>
			)}
		</div>
	)}
</ApologeticaLayout>
