---
import { getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";

export const prerender = true;

export async function getStaticPaths() {
	const cuadernos = await getCollection("Sta-Faustina");
	const paths = [
		{ params: { id: undefined }, props: { cuaderno: null } },
		...cuadernos.map((c) => ({
			params: { id: c.id },
			props: { cuaderno: c },
		})),
	];
	return paths;
}

const { cuaderno } = Astro.props;
const cuadernos = (await getCollection("Sta-Faustina")).sort(
	(a, b) => (a.data.numero ?? 0) - (b.data.numero ?? 0)
);

const title = cuaderno ? cuaderno.data.title : "Diario de Santa Faustina";
const Content = cuaderno ? (await render(cuaderno)).Content : null;
const currentSlug = cuaderno?.id ?? "";
---

<Layout title={`${title} — Diario de Santa Faustina`}>
	<style>
		.faustina-sidebar {
			width: 260px;
			flex-shrink: 0;
		}
		@media (max-width: 767px) {
			.faustina-sidebar {
				position: fixed;
				top: 0;
				left: -260px;
				height: 100%;
				z-index: 55;
				transition: left 0.3s ease;
			}
			.faustina-sidebar.open {
				left: 0;
			}
		}
	</style>

	<div class="flex h-screen relative bg-amber-50/70 dark:bg-gray-900 transition-colors duration-300">
		<!-- Overlay móvil -->
		<div
			id="sidebarOverlay"
			class="fixed inset-0 bg-black/50 z-40 hidden md:hidden"
		></div>

		<!-- Botón menú móvil -->
		<button
			id="menuToggle"
			class="md:hidden fixed top-4 right-4 z-[60] bg-rose-400/90 text-white p-2.5 rounded-full shadow-lg hover:bg-rose-500 transition backdrop-blur-sm"
			aria-label="Abrir menú"
		>
			<svg id="menuIcon" xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
			</svg>
			<svg id="closeIcon" xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
			</svg>
		</button>

		<!-- Sidebar -->
		<aside
			id="faustinasidebar"
			class="faustina-sidebar h-screen overflow-y-auto bg-stone-100 dark:bg-gray-800 border-r border-stone-200 dark:border-gray-700 flex flex-col"
		>
			<!-- Cabecera del sidebar -->
			<div class="px-4 py-5 border-b border-stone-200 dark:border-gray-700">
				<div class="flex items-center justify-between mb-3">
					<a href="/" class="flex items-center gap-2 text-rose-400 dark:text-rose-300 hover:text-rose-500 dark:hover:text-rose-200 transition text-sm">
						<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
						</svg>
						Inicio
					</a>
					<button
						id="faustinaSearchBtn"
						class="p-1.5 rounded-lg text-gray-500 dark:text-gray-400 hover:bg-stone-200 dark:hover:bg-gray-700 hover:text-rose-500 dark:hover:text-rose-300 transition"
						aria-label="Buscar en el Diario"
						title="Buscar en el Diario"
					>
						<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
						</svg>
					</button>
				</div>
				<h1 class="text-base font-bold text-gray-800 dark:text-gray-100 leading-tight">
					Diario de Santa Faustina
				</h1>
				<p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Misericordia Divina</p>
			</div>

			<!-- Lista de cuadernos -->
			<nav class="flex-1 py-3 px-2">
				<a
					href="/faustina"
					class={`flex items-center gap-2 px-3 py-2 rounded-lg text-sm transition mb-1 ${
						!cuaderno
							? "bg-rose-300 dark:bg-rose-400/40 text-rose-900 dark:text-rose-100 font-semibold"
							: "text-gray-700 dark:text-gray-200 hover:bg-stone-200 dark:hover:bg-gray-700"
					}`}
				>
					<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
					</svg>
					Inicio
				</a>

				<p class="text-xs font-semibold text-gray-400 dark:text-gray-500 uppercase tracking-wider px-3 py-2 mt-2">
					Los seis cuadernos
				</p>

				{cuadernos.map((c) => (
					<div class="mb-1">
						<a
							href={`/faustina/${c.id}`}
							class={`flex items-center gap-2 px-3 py-2 rounded-lg text-sm transition ${
								c.id === currentSlug
									? "bg-rose-300 dark:bg-rose-400/40 text-rose-900 dark:text-rose-100 font-semibold"
									: "text-gray-700 dark:text-gray-200 hover:bg-stone-200 dark:hover:bg-gray-700"
							}`}
						>
							<span class={`flex-shrink-0 w-6 h-6 rounded-full text-xs font-bold flex items-center justify-center ${
								c.id === currentSlug
									? "bg-rose-200/60 text-rose-800"
									: "bg-rose-100 dark:bg-rose-900/40 text-rose-500 dark:text-rose-400"
							}`}>
								{c.data.numero}
							</span>
							{c.data.title}
						</a>
						{c.id === currentSlug && import.meta.env.DEV && (
							<button
								data-slug={c.id}
								class="format-faustina-btn mt-1 ml-2 flex items-center gap-1.5 px-2.5 py-1 rounded text-xs bg-amber-100 dark:bg-amber-900/30 text-amber-800 dark:text-amber-300 hover:bg-amber-200 dark:hover:bg-amber-800/40 transition w-fit"
								title="Formatear numerales sin etiqueta"
							>
								<svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z" />
								</svg>
								Formatear numerales
							</button>
						)}
					</div>
				))}
			</nav>

			<!-- Pie del sidebar -->
			<div class="px-4 py-3 border-t border-stone-200 dark:border-gray-700">
				<p class="text-xs text-gray-400 dark:text-gray-500 text-center">
					Sta. Faustina Kowalska<br/>1905 – 1938
				</p>
			</div>
		</aside>

		<!-- Contenido principal -->
		<main class="flex-1 overflow-y-auto bg-amber-50 dark:bg-gray-950 md:bg-stone-200 md:dark:bg-gray-950 transition-colors duration-300">
			<div class="max-w-3xl mx-auto px-4 py-8 md:py-10">
				{Content ? (
					<article class="faustina-content bg-amber-50 dark:bg-gray-900 rounded-xl shadow-sm md:shadow-md p-6 md:p-10 prose-faustina">
						<Content />
					</article>
				) : (
					<!-- Página de bienvenida -->
					<div class="welcome-faustina">
						<div class="text-center mb-10">
							<div class="inline-flex items-center justify-center w-20 h-20 rounded-full overflow-hidden mb-4 shadow-lg">
								<img src="/Faustina.jpg" alt="Diario de Santa Faustina" class="w-full h-full object-cover" />
							</div>
							<h1 class="text-3xl md:text-4xl font-bold text-gray-800 dark:text-gray-100 mb-3">
								Diario de Santa Faustina
							</h1>
							<p class="text-rose-400 dark:text-rose-300 font-semibold text-lg mb-2">
								La Misericordia Divina en mi alma
							</p>
							<p class="text-gray-600 dark:text-gray-300 max-w-xl mx-auto text-sm leading-relaxed">
								El Diario de Santa Faustina Kowalska recoge las experiencias místicas
								y los mensajes recibidos de Jesucristo sobre la Divina Misericordia.
								Escrito entre 1934 y 1938, es considerado uno de los grandes textos
								espirituales del siglo XX.
							</p>
						</div>

						<div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
							{cuadernos.map((c) => (
								<a
									href={`/faustina/${c.id}`}
									class="group bg-amber-50 dark:bg-gray-800 border border-amber-200 dark:border-gray-700 rounded-xl p-5 hover:border-rose-400 dark:hover:border-rose-500 hover:shadow-md transition-all"
								>
									<div class="flex items-start gap-3">
										<span class="flex-shrink-0 w-9 h-9 rounded-full bg-rose-100 dark:bg-rose-900/40 text-rose-400 dark:text-rose-300 text-sm font-bold flex items-center justify-center group-hover:bg-rose-300 group-hover:text-rose-900 transition-colors">
											{c.data.numero}
										</span>
										<div>
											<h2 class="font-bold text-gray-800 dark:text-gray-100 group-hover:text-rose-500 dark:group-hover:text-rose-300 transition-colors">
												{c.data.title}
											</h2>
											<p class="text-xs text-gray-500 dark:text-gray-400 mt-1 leading-snug">
												{c.data.description}
											</p>
										</div>
									</div>
								</a>
							))}
						</div>

						<div class="mt-10 bg-rose-50 dark:bg-rose-900/20 border border-rose-200 dark:border-rose-800 rounded-xl p-6 text-center">
							<p class="text-rose-600 dark:text-rose-300 italic text-lg font-medium">
								«Jesús, en Ti confío.»
							</p>
							<p class="text-rose-400 dark:text-rose-300 text-sm mt-2">
								— Inscripción de la Imagen de la Misericordia Divina
							</p>
						</div>
					</div>
				)}
			</div>
		</main>
	</div>
	<!-- Diálogo de búsqueda -->
	<div
		id="faustinaSearchOverlay"
		class="hidden fixed inset-0 bg-black/60 z-[200] items-start justify-center p-4 pt-14 md:pt-10"
		role="dialog" aria-modal="true"
	>
		<div class="w-full max-w-xl bg-white dark:bg-gray-900 rounded-xl shadow-2xl flex flex-col max-h-[88vh] overflow-hidden">
			<div class="flex items-center gap-3 px-4 py-3 border-b border-gray-200 dark:border-gray-700">
				<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-rose-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
				</svg>
				<input
					type="text"
					id="faustinaSearchInput"
					placeholder="Buscar en el Diario..."
					autocomplete="off"
					class="flex-1 min-w-0 bg-transparent text-gray-900 dark:text-gray-100 placeholder-gray-400 dark:placeholder-gray-500 text-base outline-none"
				/>
				<div class="flex items-center gap-1.5 shrink-0 border-l border-gray-200 dark:border-gray-700 pl-3">
					<span class="text-xs text-gray-400 dark:text-gray-500 font-mono">#</span>
					<input
						type="number"
						id="faustinaSearchNumeral"
						placeholder="1231"
						min="1"
						autocomplete="off"
						class="w-16 bg-transparent text-gray-900 dark:text-gray-100 placeholder-gray-400 dark:placeholder-gray-500 text-sm outline-none [appearance:textfield] [&::-webkit-inner-spin-button]:appearance-none [&::-webkit-outer-spin-button]:appearance-none"
					/>
				</div>
				<button id="faustinaSearchClose" class="p-1.5 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 text-gray-500 transition flex-shrink-0">
					<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
					</svg>
				</button>
			</div>
			<div id="fsStatus" class="px-4 py-2 text-xs text-gray-500 dark:text-gray-400 border-b border-gray-100 dark:border-gray-800 hidden"></div>
			<div id="fsResults" class="overflow-y-auto flex-1 p-3 space-y-2">
				<div id="fsInitial" class="flex flex-col items-center justify-center py-14 text-center">
					<svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 text-gray-300 dark:text-gray-600 mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
					</svg>
					<p class="text-gray-500 dark:text-gray-400 text-sm">Escribe al menos 3 letras para buscar</p>
					<p class="text-gray-400 dark:text-gray-500 text-xs mt-1">en todos los cuadernos del Diario</p>
				</div>
				<div id="fsLoading" class="hidden items-center justify-center py-14 flex-col">
					<div class="w-8 h-8 border-2 border-rose-400 border-t-transparent rounded-full animate-spin mb-3"></div>
					<p class="text-gray-500 dark:text-gray-400 text-sm">Buscando...</p>
				</div>
				<div id="fsEmpty" class="hidden items-center justify-center py-14 flex-col text-center">
					<p class="text-gray-600 dark:text-gray-400 text-sm font-medium">Sin resultados</p>
					<p class="text-gray-400 dark:text-gray-500 text-xs mt-1">Intenta con otras palabras</p>
				</div>
				<div id="fsResultsList" class="hidden space-y-2"></div>
			</div>
		</div>
	</div>
</Layout>

<style is:global>
	/* Estilos del contenido del Diario */
	.faustina-content h1 {
		font-size: 1.75rem;
		font-weight: 800;
		color: #be7187;
		margin-bottom: 0.5rem;
		text-align: center;
		letter-spacing: 0.05em;
	}
	:is(.dark) .faustina-content h1 {
		color: #fca5a5;
	}

	.faustina-content h2 {
		font-size: 1rem;
		font-weight: 700;
		color: #78350f;
		margin-top: 2.5rem;
		margin-bottom: 1rem;
		padding-bottom: 0.4rem;
		border-bottom: 1px solid #fde68a;
		text-transform: uppercase;
		letter-spacing: 0.04em;
	}
	:is(.dark) .faustina-content h2 {
		color: #fbbf24;
		border-bottom-color: #78350f;
	}

	.faustina-fecha {
		text-align: center;
		font-style: italic;
		color: #92400e;
		font-size: 0.9rem;
		margin-bottom: 1.5rem;
	}
	:is(.dark) .faustina-fecha {
		color: #d97706;
	}

	.faustina-content p {
		margin: 0.9rem 0;
		line-height: 1.85;
		color: #292524;
		text-align: justify;
		hyphens: auto;
		white-space: pre-line;
	}
	:is(.dark) .faustina-content p {
		color: #e7e5e4;
	}

	.faustina-num {
		display: inline;
		color: #78350f;
		font-size: 1rem;
		font-weight: 800;
		margin-right: 0.35rem;
	}
	:is(.dark) .faustina-num {
		color: #fbbf24;
	}

	/* Estados del diálogo de búsqueda */
	#fsLoading:not(.hidden),
	#fsEmpty:not(.hidden),
	#fsInitial:not(.hidden) {
		display: flex;
	}
	#fsResults::-webkit-scrollbar { width: 5px; }
	#fsResults::-webkit-scrollbar-track { background: transparent; }
	#fsResults::-webkit-scrollbar-thumb { background: #d6d3d1; border-radius: 3px; }
	.dark #fsResults::-webkit-scrollbar-thumb { background: #4b5563; }
	.fs-match { background-color: #fde68a; border-radius: 2px; padding: 0 1px; }
	.dark .fs-match { background-color: #713f12; color: #fef9c3; }

	.faustina-content hr {
		border: none;
		border-top: 1px solid #fde68a;
		margin: 2rem 0;
	}
	:is(.dark) .faustina-content hr {
		border-top-color: #44403c;
	}
</style>

<script>
	function initSidebar() {
		const menuToggle = document.getElementById('menuToggle');
		const sidebar = document.querySelector('aside');
		const overlay = document.getElementById('sidebarOverlay');
		const menuIcon = document.getElementById('menuIcon');
		const closeIcon = document.getElementById('closeIcon');

		function openSidebar() {
			sidebar?.classList.add('open');
			overlay?.classList.remove('hidden');
			menuIcon?.classList.add('hidden');
			closeIcon?.classList.remove('hidden');
		}

		function closeSidebar() {
			sidebar?.classList.remove('open');
			overlay?.classList.add('hidden');
			menuIcon?.classList.remove('hidden');
			closeIcon?.classList.add('hidden');
		}

		menuToggle?.addEventListener('click', () => {
			if (sidebar?.classList.contains('open')) {
				closeSidebar();
			} else {
				openSidebar();
			}
		});

		overlay?.addEventListener('click', closeSidebar);
	}

	// Inyecta id="entry-N" en cada span.faustina-num y hace scroll al hash
	function initEntryAnchors() {
		document.querySelectorAll<HTMLElement>('.faustina-num').forEach(span => {
			const num = span.textContent?.trim();
			if (num) span.id = `entry-${num}`;
		});

		const hash = window.location.hash;
		if (hash?.startsWith('#entry-')) {
			const target = document.querySelector<HTMLElement>(hash);
			if (target) {
				setTimeout(() => {
					target.scrollIntoView({ behavior: 'smooth', block: 'center' });
				}, 100);
			}
		}
	}

	document.addEventListener('astro:page-load', initEntryAnchors);
	initEntryAnchors();

	document.addEventListener('astro:page-load', initSidebar);
	initSidebar();

	// Botón formatear numerales
	function initFormatBtn() {
		document.querySelectorAll('.format-faustina-btn').forEach(btn => {
			btn.addEventListener('click', async () => {
				const slug = (btn as HTMLElement).dataset.slug;
				if (!slug) return;

				btn.textContent = 'Formateando...';
				(btn as HTMLButtonElement).disabled = true;

				try {
					const res = await fetch('/api/format-faustina', {
						method: 'POST',
						headers: { 'Content-Type': 'application/json' },
						body: JSON.stringify({ slug }),
					});
					const data = await res.json();

					if (res.ok) {
						btn.textContent = data.count > 0
							? `✓ ${data.count} numeral(es) formateados`
							: '✓ Sin cambios';
						if (data.count > 0) {
							setTimeout(() => window.location.reload(), 1000);
						} else {
							setTimeout(() => {
								btn.textContent = 'Formatear numerales';
								(btn as HTMLButtonElement).disabled = false;
							}, 2000);
						}
					} else {
						btn.textContent = `Error: ${data.error}`;
						(btn as HTMLButtonElement).disabled = false;
					}
				} catch (e) {
					btn.textContent = 'Error de red';
					(btn as HTMLButtonElement).disabled = false;
				}
			});
		});
	}

	document.addEventListener('astro:page-load', initFormatBtn);
	initFormatBtn();

	// Búsqueda Faustina
	function initFaustinaSearch() {
		const overlay = document.getElementById('faustinaSearchOverlay');
		const input = document.getElementById('faustinaSearchInput') as HTMLInputElement;
		const numeralInput = document.getElementById('faustinaSearchNumeral') as HTMLInputElement;
		const closeBtn = document.getElementById('faustinaSearchClose');
		const openBtn = document.getElementById('faustinaSearchBtn');
		const statusEl = document.getElementById('fsStatus');
		const initialEl = document.getElementById('fsInitial');
		const loadingEl = document.getElementById('fsLoading');
		const emptyEl = document.getElementById('fsEmpty');
		const listEl = document.getElementById('fsResultsList');

		if (!overlay) return;

		function openDialog() {
			overlay!.classList.remove('hidden');
			overlay!.classList.add('flex');
			document.body.style.overflow = 'hidden';
			setTimeout(() => input?.focus(), 50);
		}

		function closeDialog() {
			overlay!.classList.add('hidden');
			overlay!.classList.remove('flex');
			document.body.style.overflow = '';
			if (input) input.value = '';
			if (numeralInput) numeralInput.value = '';
			showState('initial');
			if (statusEl) { statusEl.textContent = ''; statusEl.classList.add('hidden'); }
			if (listEl) listEl.innerHTML = '';
			lastQuery = '';
		}

		function showState(state: 'initial' | 'loading' | 'empty' | 'results') {
			initialEl?.classList.toggle('hidden', state !== 'initial');
			loadingEl?.classList.toggle('hidden', state !== 'loading');
			emptyEl?.classList.toggle('hidden', state !== 'empty');
			listEl?.classList.toggle('hidden', state !== 'results');
		}

		function escapeHtml(s: string) {
			return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
		}

		function highlight(text: string, query: string): string {
			const norm = (t: string) => t.normalize('NFD').replace(/[\u0300-\u036f]/g,'').replace(/[,;:.!?¡¿'"«»""'']/g,'').toLowerCase();
			const idx = norm(text).indexOf(norm(query));
			if (idx === -1) return escapeHtml(text);
			return escapeHtml(text.slice(0, idx))
				+ `<mark class="fs-match">${escapeHtml(text.slice(idx, idx + query.length))}</mark>`
				+ escapeHtml(text.slice(idx + query.length));
		}

		function renderResults(results: { title: string; slug: string; entryNum: string; snippet: string }[], query: string, isNumeral = false) {
			if (!results?.length) { showState('empty'); return; }

			if (statusEl) {
				const total = results.length;
				statusEl.textContent = isNumeral
					? `Entrada ${results[0].entryNum} — ${results[0].title}`
					: total >= 100
						? `Más de 100 resultados (mostrando los primeros 100)`
						: `${total} resultado${total !== 1 ? 's' : ''} encontrado${total !== 1 ? 's' : ''}`;
				statusEl.classList.remove('hidden');
			}

			if (listEl) {
				listEl.innerHTML = results.map(r => `
					<a href="/faustina/${r.slug}#entry-${r.entryNum}"
						class="fs-card block p-3 rounded-lg border border-gray-200 dark:border-gray-700 hover:border-rose-300 dark:hover:border-rose-600 hover:bg-rose-50 dark:hover:bg-rose-950/20 transition-all"
					>
						<div class="flex items-start justify-between gap-2 mb-1">
							<span class="font-semibold text-rose-600 dark:text-rose-400 text-sm">${escapeHtml(r.title)}</span>
							<span class="text-xs text-gray-500 dark:text-gray-400 whitespace-nowrap flex-shrink-0">Entrada ${r.entryNum}</span>
						</div>
						<p class="text-sm text-gray-700 dark:text-gray-300 leading-relaxed">${isNumeral ? escapeHtml(r.snippet) : highlight(r.snippet, query)}</p>
					</a>
				`).join('');
			}

			showState('results');
			listEl?.querySelectorAll('.fs-card').forEach(card => {
				card.addEventListener('click', closeDialog);
			});
		}

		let searchTimeout: ReturnType<typeof setTimeout>;
		let lastQuery = '';

		async function performSearch(query: string) {
			if (query === lastQuery) return;
			lastQuery = query;
			if (!query || query.length < 3) { showState('initial'); return; }

			showState('loading');
			if (statusEl) statusEl.classList.add('hidden');

			try {
				const res = await fetch(`/api/faustina-search?q=${encodeURIComponent(query)}`);
				const { results } = await res.json();
				if (query !== lastQuery) return;
				renderResults(results, query, false);
			} catch {
				showState('empty');
			}
		}

		async function performNumeralSearch(numeral: string) {
			const key = `#${numeral}`;
			if (key === lastQuery) return;
			lastQuery = key;

			showState('loading');
			if (statusEl) statusEl.classList.add('hidden');

			try {
				const res = await fetch(`/api/faustina-search?numeral=${encodeURIComponent(numeral)}`);
				const { results } = await res.json();
				if (key !== lastQuery) return;
				renderResults(results, numeral, true);
			} catch {
				showState('empty');
			}
		}

		input?.addEventListener('input', () => {
			if (numeralInput.value) { numeralInput.value = ''; lastQuery = ''; }
			clearTimeout(searchTimeout);
			searchTimeout = setTimeout(() => performSearch(input.value.trim()), 400);
		});

		numeralInput?.addEventListener('input', () => {
			const n = numeralInput.value.trim();
			if (input.value) { input.value = ''; lastQuery = ''; }
			clearTimeout(searchTimeout);
			if (!n) { showState('initial'); lastQuery = ''; return; }
			searchTimeout = setTimeout(() => performNumeralSearch(n), 400);
		});

		openBtn?.addEventListener('click', openDialog);
		closeBtn?.addEventListener('click', closeDialog);
		overlay?.addEventListener('click', (e) => { if (e.target === overlay) closeDialog(); });
		document.addEventListener('keydown', (e) => {
			if (e.key === 'Escape' && !overlay!.classList.contains('hidden')) closeDialog();
		});
	}

	document.addEventListener('astro:page-load', initFaustinaSearch);
	initFaustinaSearch();
</script>
