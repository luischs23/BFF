---

<Layout title="Sagrada Biblia">
	<!-- Botón de configuración (esquina superior izquierda) -->
	<button
		id="settingsBtn"
		class="fixed top-4 left-4 z-50 w-12 h-12 rounded-2xl bg-gray-800 dark:bg-gray-700 hover:bg-gray-700 dark:hover:bg-gray-600 transition-colors shadow-lg flex items-center justify-center"
		aria-label="Configuración"
	>
		<svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
			<path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h10M4 18h7" />
			<circle cx="18" cy="12" r="2" fill="currentColor" stroke="none"/>
			<circle cx="14" cy="6" r="2" fill="currentColor" stroke="none"/>
			<circle cx="11" cy="18" r="2" fill="currentColor" stroke="none"/>
		</svg>
	</button>

	<!-- Diálogo de configuración -->
	<div id="settingsDialog" class="fixed inset-0 z-[60] hidden items-center justify-center bg-black/60 backdrop-blur-sm">
		<div class="bg-white dark:bg-gray-900 rounded-2xl p-6 mx-4 w-full max-w-xs shadow-2xl border border-gray-200 dark:border-gray-700">
			<div class="flex items-center justify-between mb-5">
				<h2 class="text-lg font-bold text-gray-900 dark:text-gray-100">Configuración</h2>
				<button id="settingsClose" class="p-1.5 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors text-gray-500 dark:text-gray-400">
					<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
						<path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
					</svg>
				</button>
			</div>

			<!-- Modo oscuro -->
			<div class="flex items-center justify-between py-3 border-b border-gray-100 dark:border-gray-800">
				<div class="flex items-center gap-3">
					<div class="w-8 h-8 rounded-lg bg-gray-100 dark:bg-gray-800 flex items-center justify-center">
						<svg class="w-4 h-4 text-gray-600 dark:text-gray-400 hidden dark:block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
							<path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
						</svg>
						<svg class="w-4 h-4 text-gray-600 dark:text-gray-400 block dark:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
							<path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
						</svg>
					</div>
					<span class="text-sm font-medium text-gray-700 dark:text-gray-300">Modo oscuro</span>
				</div>
				<!-- Toggle switch -->
				<button
					id="darkModeToggle"
					role="switch"
					aria-checked="false"
					class="relative w-11 h-6 rounded-full transition-colors duration-200 focus:outline-none bg-gray-300 dark:bg-amber-500"
				>
					<span class="absolute top-0.5 left-0.5 w-5 h-5 rounded-full bg-white shadow transition-transform duration-200 dark:translate-x-5"></span>
					<!-- Sol (modo claro) -->
					<svg id="sunIcon" class="hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor"></svg>
					<!-- Luna (modo oscuro) — necesarios para el script darkMode.ts -->
					<svg id="moonIcon" class="hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor"></svg>
				</button>
			</div>

			<!-- Tamaño de texto -->
			<div class="py-3">
				<div class="flex items-center gap-3 mb-3">
					<div class="w-8 h-8 rounded-lg bg-gray-100 dark:bg-gray-800 flex items-center justify-center">
						<svg class="w-4 h-4 text-gray-600 dark:text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
							<path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
						</svg>
					</div>
					<span class="text-sm font-medium text-gray-700 dark:text-gray-300">Tamaño de texto</span>
				</div>
				<div class="grid grid-cols-4 gap-1.5">
					{[
						{ size: 'small', label: 'A', style: 'text-xs' },
						{ size: 'medium', label: 'A', style: 'text-sm' },
						{ size: 'large', label: 'A', style: 'text-base' },
						{ size: 'xlarge', label: 'A', style: 'text-lg' },
					].map(({ size, label, style }) => (
						<button
							class={`font-size-option py-2 rounded-lg border border-gray-200 dark:border-gray-700 font-bold transition-colors hover:border-amber-400 dark:hover:border-amber-500 text-gray-700 dark:text-gray-300 ${style}`}
							data-size={size}
						>
							{label}
						</button>
					))}
				</div>
			</div>
		</div>
	</div>

	<main class="min-h-screen flex flex-col items-center px-5 pt-20 pb-12">
		<h1 class="text-center text-3xl font-bold mb-1 text-gray-900 dark:text-gray-100 tracking-tight">BFF</h1>
		<p class="text-gray-400 dark:text-gray-500 text-center mb-8 text-xs tracking-widest uppercase">
			Bases para una Fe Firme
		</p>

		<!-- Tarjetas principales -->
		<div class="grid grid-cols-2 gap-3 w-full max-w-xs mb-8">
			<!-- Biblia Jerusalén -->
			<a
				href="/biblia"
				class="flex flex-col p-4 rounded-3xl bg-gray-900 hover:bg-gray-800 transition-all duration-200 hover:scale-[1.02] group border border-white/5"
			>
				<div class="w-12 h-12 rounded-2xl bg-amber-500 flex items-center justify-center mb-3 shadow-lg shadow-amber-900/40">
					<svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
						<path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
					</svg>
				</div>
				<span class="text-white font-semibold text-sm leading-tight">Biblia</span>
				<span class="text-gray-500 text-xs mt-0.5">Jerusalén</span>
			</a>

			<!-- Diario de Sta. Faustina -->
			<a
				href="/faustina"
				class="flex flex-col p-4 rounded-3xl bg-gray-900 hover:bg-gray-800 transition-all duration-200 hover:scale-[1.02] group border border-white/5"
			>
				<div class="w-12 h-12 rounded-2xl bg-rose-400 flex items-center justify-center mb-3 shadow-lg shadow-rose-900/40">
					<svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
						<path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
					</svg>
				</div>
				<span class="text-white font-semibold text-sm leading-tight">Sta. Faustina</span>
				<span class="text-gray-500 text-xs mt-0.5">Diario</span>
			</a>
		</div>

		<!-- Cards de libros del día -->
		<div class="w-full max-w-xs">
			<p class="text-[10px] font-semibold uppercase tracking-[0.2em] text-gray-500 dark:text-gray-600 mb-3">
				Lecturas del día
			</p>
			<div class="flex flex-col gap-1.5">
				{dailyCards.map(({ section, color, textColor, card }) => (
					<a
						href={`/biblia/${card.slug}#chapter-${card.chapter}-verse-${card.verseNum}`}
						class="flex items-center gap-3 px-4 py-3 rounded-2xl bg-gray-900 hover:bg-gray-800 border border-white/5 hover:border-white/10 transition-all duration-150 group"
					>
						<span class={`shrink-0 w-2 h-2 rounded-full ${color}`}></span>
						<div class="min-w-0 flex-1">
							<div class="flex items-baseline gap-1.5 mb-0.5">
								<span class={`text-[9px] font-bold uppercase tracking-wider ${textColor} shrink-0`}>{section}</span>
								<span class="text-gray-300 text-xs font-medium truncate">{card.book}</span>
							</div>
							<p class="text-gray-500 text-[11px] leading-snug italic truncate">"{card.verse}"</p>
						</div>
						<span class="text-gray-600 text-[10px] font-mono shrink-0">{card.ref}</span>
						<svg class="shrink-0 w-3 h-3 text-gray-700 group-hover:text-gray-400 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
							<path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
						</svg>
					</a>
				))}
			</div>
		</div>

		<!-- Links solo en desarrollo -->
		{isDev && (
			<div class="flex flex-col sm:flex-row gap-3 flex-wrap justify-center mt-6">
				<a
					href="/buscar"
					class="px-6 py-2.5 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition text-sm font-semibold text-center"
				>
					Buscar Pasajes
				</a>
				<a
					href="/admin"
					class="px-6 py-2.5 bg-gray-600 text-white rounded-lg hover:bg-gray-700 transition text-sm font-semibold text-center"
				>
					Administrar
				</a>
			</div>
		)}
	</main>
</Layout>

<script>
	import { initDarkMode } from '../scripts/biblia/darkMode';

	// Inicializar dark mode (toggle en el diálogo)
	document.addEventListener('DOMContentLoaded', initDarkMode);
	document.addEventListener('astro:page-load', initDarkMode);

	// Diálogo de configuración
	function initSettings() {
		const btn = document.getElementById('settingsBtn');
		const dialog = document.getElementById('settingsDialog');
		const closeBtn = document.getElementById('settingsClose');

		if (!btn || !dialog) return;

		btn.addEventListener('click', () => {
			dialog.classList.remove('hidden');
			dialog.classList.add('flex');
			syncSettingsState();
		});

		closeBtn?.addEventListener('click', closeDialog);

		dialog.addEventListener('click', (e) => {
			if (e.target === dialog) closeDialog();
		});

		function closeDialog() {
			dialog.classList.add('hidden');
			dialog.classList.remove('flex');
		}

		// Tamaño de texto
		const fontSizeOptions = document.querySelectorAll<HTMLButtonElement>('.font-size-option');

		function syncSettingsState() {
			// Tamaño activo
			const saved = localStorage.getItem('bibleFontSize') || 'medium';
			fontSizeOptions.forEach(opt => {
				const isActive = opt.dataset.size === saved;
				opt.classList.toggle('bg-amber-100', isActive);
				opt.classList.toggle('dark:bg-amber-900', isActive);
				opt.classList.toggle('border-amber-400', isActive);
				opt.classList.toggle('dark:border-amber-500', isActive);
			});
		}

		fontSizeOptions.forEach(opt => {
			opt.addEventListener('click', () => {
				const size = opt.dataset.size || 'medium';
				localStorage.setItem('bibleFontSize', size);
				syncSettingsState();
			});
		});
	}

	document.addEventListener('DOMContentLoaded', initSettings);
	document.addEventListener('astro:page-load', initSettings);
</script>
