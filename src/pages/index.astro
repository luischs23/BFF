					class="px-6 py-2.5 bg-gray-600 text-white rounded-lg hover:bg-gray-700 transition text-sm font-semibold text-center"
				>
					Administrar
				</a>
			</div>
		)}
	</main>
</Layout>

<script>
	import { initDarkMode } from '../scripts/biblia/darkMode';

	// Inicializar dark mode (toggle en el diálogo)
	document.addEventListener('DOMContentLoaded', initDarkMode);
	document.addEventListener('astro:page-load', initDarkMode);

	// Diálogo de configuración
	function initSettings() {
		const btn = document.getElementById('settingsBtn');
		const dialog = document.getElementById('settingsDialog');
		const closeBtn = document.getElementById('settingsClose');

		if (!btn || !dialog) return;

		btn.addEventListener('click', () => {
			dialog.classList.remove('hidden');
			dialog.classList.add('flex');
			syncSettingsState();
		});

		closeBtn?.addEventListener('click', closeDialog);

		dialog.addEventListener('click', (e) => {
			if (e.target === dialog) closeDialog();
		});

		function closeDialog() {
			dialog.classList.add('hidden');
			dialog.classList.remove('flex');
		}

		// Tamaño de texto
		const fontSizeOptions = document.querySelectorAll<HTMLButtonElement>('.font-size-option');

		function syncSettingsState() {
			// Tamaño activo
			const saved = localStorage.getItem('bibleFontSize') || 'medium';
			fontSizeOptions.forEach(opt => {
				const isActive = opt.dataset.size === saved;
				opt.classList.toggle('bg-amber-100', isActive);
				opt.classList.toggle('dark:bg-amber-900', isActive);
				opt.classList.toggle('border-amber-400', isActive);
				opt.classList.toggle('dark:border-amber-500', isActive);
			});
		}

		fontSizeOptions.forEach(opt => {
			opt.addEventListener('click', () => {
				const size = opt.dataset.size || 'medium';
				localStorage.setItem('bibleFontSize', size);
				syncSettingsState();
			});
		});
	}

	document.addEventListener('DOMContentLoaded', initSettings);
	document.addEventListener('astro:page-load', initSettings);

	// Versículos dinámicos para las lecturas del día
	function getDateSeed() {
		const d = new Date();
		return d.getFullYear() * 10000 + (d.getMonth() + 1) * 100 + d.getDate();
	}

	async function initDailyReadings() {
		const cards = document.querySelectorAll<HTMLAnchorElement>('[data-daily-slug]');
		if (!cards.length) return;
		const cacheKey = 'dailyReadings_' + getDateSeed();
		let cache: Record<string, { text: string; chapter: number; verse: string; verseNum: number }> = {};
		try { cache = JSON.parse(sessionStorage.getItem(cacheKey) ?? '{}'); } catch {}

		for (const card of cards) {
			const slug = card.dataset.dailySlug!;
			const salt = card.dataset.dailySalt!;
			let data = cache[slug];
			if (!data) {
				try {
					const res = await fetch(`/api/verse-of-day?slug=${encodeURIComponent(slug)}&salt=${salt}`);
					if (res.ok) {
						data = await res.json();
						cache[slug] = data;
					}
				} catch {}
			}
			if (!data) continue;
			const verseEl = card.querySelector('.daily-verse');
			const refEl = card.querySelector('.daily-ref');
			if (verseEl) verseEl.textContent = `"${data.text}"`;
			if (refEl) refEl.textContent = `${data.chapter},${data.verse}`;
			card.href = `/biblia/${slug}#chapter-${data.chapter}-verse-${data.verseNum}`;
		}
		try { sessionStorage.setItem(cacheKey, JSON.stringify(cache)); } catch {}
	}

	document.addEventListener('DOMContentLoaded', initDailyReadings);
	document.addEventListener('astro:page-load', initDailyReadings);
</script>
