---
import { getCollection, render } from "astro:content";
import SumaTeologicaLayout from "../../components/suma-teologica/SumaTeologicaLayout.astro";
import type { PartTree, TreeNode } from "../../components/suma-teologica/SumaTeologicaSidebar.astro";

const PARTES: Record<string, { label: string }> = {
	"parte-i": { label: "Parte I — Dios y la Creación" },
};

const FOLDER_LABELS: Record<string, string> = {
	'la-ciencia-teologica':       'La Ciencia Teológica',
	'dios':                        'Dios',
	'dios-uno':                    'Dios Uno',
	'dios-trino':                  'Dios Trino',
	'la-creacion-y-las-criaturas': 'La Creación y las Criaturas',
	'los-angeles-y-los-demonios':  'Los Ángeles y los Demonios',
	'la-creacion-del-mundo':       'La Creación del Mundo',
	'el-hombre-como-criatura':     'El Hombre como Criatura',
	'el-cosmos':                   'El Cosmos',
};

function formatFolderName(s: string): string {
	return FOLDER_LABELS[s] ?? s.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
}

function getMinCuestion(node: TreeNode): number {
  if (node.cuestion !== undefined) return node.cuestion;
  if (node.children.length === 0) return Infinity;
  return Math.min(...node.children.map(getMinCuestion));
}

function sortNodes(nodes: TreeNode[]): TreeNode[] {
  for (const node of nodes) {
    if (node.children.length > 0) sortNodes(node.children);
  }
  return nodes.sort((a, b) => getMinCuestion(a) - getMinCuestion(b));
}

function buildTree(cuestiones: Awaited<ReturnType<typeof getCollection<"suma-teologica">>>): PartTree[] {
  const parts: PartTree[] = [];

  for (const [parteKey, parteMeta] of Object.entries(PARTES)) {
    const parteCuestiones = cuestiones.filter(c => c.id.startsWith(parteKey + '/'));
    if (parteCuestiones.length === 0) continue;

    const nodeMap = new Map<string, TreeNode>();
    const roots: TreeNode[] = [];
    const sorted = parteCuestiones.sort((a, b) => a.id.localeCompare(b.id));

    for (const c of sorted) {
      const slugParts = c.id.split('/');
      for (let depth = 1; depth < slugParts.length; depth++) {
        const currentKey = slugParts.slice(0, depth + 1).join('/');
        if (!nodeMap.has(currentKey)) {
          const isLeaf = depth === slugParts.length - 1;
          const node: TreeNode = {
            slug: isLeaf ? c.id : '',
            title: isLeaf ? c.data.title : formatFolderName(slugParts[depth]),
            cuestion: isLeaf ? c.data.cuestion : undefined,
            children: [],
          };
          nodeMap.set(currentKey, node);
          if (depth === 1) roots.push(node);
          else nodeMap.get(slugParts.slice(0, depth).join('/'))?.children.push(node);
        } else if (depth === slugParts.length - 1) {
          const node = nodeMap.get(currentKey)!;
          node.slug = c.id;
          node.title = c.data.title;
          node.cuestion = c.data.cuestion;
        }
      }
    }

    parts.push({ key: parteKey, label: parteMeta.label, nodes: sortNodes(roots) });
  }

  return parts;
}

const { id } = Astro.params;
const currentSlug = Array.isArray(id) ? id.join('/') : (id ?? '');

const allCuestiones = await getCollection("suma-teologica");
const tree = buildTree(allCuestiones);

const cuestion = currentSlug
	? (allCuestiones.find(c => c.id === currentSlug) ?? null)
	: null;

const Content = cuestion ? (await render(cuestion)).Content : null;
const pageTitle = cuestion ? cuestion.data.title : "Suma Teológica";

// Navegación prev/next
const sortedCuestiones = allCuestiones
	.filter(c => c.data.cuestion !== undefined)
	.sort((a, b) => (a.data.cuestion ?? 0) - (b.data.cuestion ?? 0));
const currentIdx = cuestion ? sortedCuestiones.findIndex(c => c.id === currentSlug) : -1;
const prevQ = currentIdx > 0 ? sortedCuestiones[currentIdx - 1] : null;
const nextQ = currentIdx >= 0 && currentIdx < sortedCuestiones.length - 1 ? sortedCuestiones[currentIdx + 1] : null;
---

<SumaTeologicaLayout title={pageTitle} currentSlug={currentSlug} tree={tree} cuestionNum={cuestion?.data.cuestion}>
	{Content && cuestion ? (
		<article class="suma-content bg-white dark:bg-gray-900 mx-2 mt-3 rounded-xl md:mx-0 md:mt-0 md:rounded-xl md:shadow-md p-4 md:p-10">
			<!-- Encabezado con navegación -->
			<div class="mb-6 pb-4 border-b border-stone-200 dark:border-gray-700">
				<div class="flex items-center justify-between gap-2 mb-2">
					{prevQ ? (
						<a href={`/suma-teologica/${prevQ.id}`} class="flex items-center gap-1 text-xs text-red-600 dark:text-red-400 hover:text-red-800 dark:hover:text-red-300 transition shrink-0" title={prevQ.data.title}>
							<svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
							<span>C.{prevQ.data.cuestion}</span>
						</a>
					) : <div class="w-10" />}
					<p class="text-xs font-semibold uppercase tracking-widest text-red-600 dark:text-red-400 text-center">
						Cuestión {cuestion.data.cuestion} · {cuestion.data.articulos} {cuestion.data.articulos === 1 ? 'artículo' : 'artículos'}
					</p>
					{nextQ ? (
						<a href={`/suma-teologica/${nextQ.id}`} class="flex items-center gap-1 text-xs text-red-600 dark:text-red-400 hover:text-red-800 dark:hover:text-red-300 transition shrink-0" title={nextQ.data.title}>
							<span>C.{nextQ.data.cuestion}</span>
							<svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
						</a>
					) : <div class="w-10" />}
				</div>
				<h1 class="text-2xl md:text-3xl font-bold text-gray-900 dark:text-gray-100">{pageTitle}</h1>
				<p class="text-xs text-gray-400 dark:text-gray-500 mt-1">{cuestion.data.seccion}</p>
			</div>
			<div class="prose prose-stone dark:prose-invert max-w-none">
				<Content />
			</div>
			<!-- Navegación al pie -->
			<div class="flex items-center justify-between mt-10 pt-6 border-t border-stone-200 dark:border-gray-700 gap-4">
				{prevQ ? (
					<a href={`/suma-teologica/${prevQ.id}`} class="flex items-center gap-2 text-sm text-red-600 dark:text-red-400 hover:text-red-800 dark:hover:text-red-300 transition min-w-0">
						<svg class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
						<span class="truncate"><span class="font-semibold">C.{prevQ.data.cuestion}</span> <span class="text-gray-500 dark:text-gray-400">{prevQ.data.title}</span></span>
					</a>
				) : <div />}
				{nextQ ? (
					<a href={`/suma-teologica/${nextQ.id}`} class="flex items-center gap-2 text-sm text-red-600 dark:text-red-400 hover:text-red-800 dark:hover:text-red-300 transition min-w-0 text-right ml-auto">
						<span class="truncate"><span class="text-gray-500 dark:text-gray-400">{nextQ.data.title}</span> <span class="font-semibold">C.{nextQ.data.cuestion}</span></span>
						<svg class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
					</a>
				) : <div />}
			</div>
		</article>
	) : cuestion ? (
		<!-- Cuestión sin contenido aún -->
		<div class="mx-2 mt-3 md:mx-0 md:mt-0">
			<div class="bg-white dark:bg-gray-900 rounded-xl md:shadow-md p-8 md:p-12 text-center">
				<p class="text-xs font-semibold uppercase tracking-widest text-red-600 dark:text-red-400 mb-4">
					{cuestion.data.seccion}
				</p>
				<h1 class="text-2xl md:text-3xl font-bold text-gray-900 dark:text-gray-100 mb-3">{pageTitle}</h1>
				<p class="text-sm text-gray-500 dark:text-gray-400">
					Cuestión {cuestion.data.cuestion} · {cuestion.data.articulos} {cuestion.data.articulos === 1 ? 'artículo' : 'artículos'}
				</p>
				<div class="mt-8 inline-flex items-center gap-2 text-xs text-stone-400 dark:text-stone-600 bg-stone-100 dark:bg-gray-800 px-4 py-2 rounded-full">
					<svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
					</svg>
					Contenido pendiente de carga
				</div>
			</div>
		</div>
	) : (
		<!-- Página de inicio -->
			<div class="px-3 pt-4 md:px-0 md:pt-0">
			<div class="text-center mb-10">
				<div class="inline-flex items-center justify-center w-20 h-20 rounded-full overflow-hidden mb-4 shadow-lg">
				<img src="/Suma.jpg" alt="Suma Teológica" class="w-full h-full object-cover" />
				</div>
				<h1 class="text-3xl md:text-4xl font-bold text-gray-800 dark:text-gray-100 mb-3">Suma Teológica</h1>
				<p class="text-red-700 dark:text-red-400 font-semibold text-lg mb-2">Santo Tomás de Aquino</p>
				<p class="text-gray-600 dark:text-gray-300 max-w-xl mx-auto text-sm leading-relaxed">
				La obra cumbre de la escolástica medieval, estructurada en tres partes y organizada en cuestiones
				y artículos que abordan sistemáticamente toda la teología cristiana.
				</p>
			</div>

			<div class="space-y-4">
				{tree.map(parte => (
				<div class="bg-red-50 dark:bg-red-950/20 border border-red-200 dark:border-red-900 rounded-xl overflow-hidden">
					<details open class="group/parte">
					<summary class="flex items-center gap-2 px-5 py-4 cursor-pointer select-none hover:bg-red-100 dark:hover:bg-red-950/40 transition list-none">
						<svg class="h-3.5 w-3.5 flex-shrink-0 text-red-600 dark:text-red-400 transition-transform group-open/parte:rotate-90" fill="none" viewBox="0 0 24 24" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
						</svg>
						<h2 class="font-bold text-sm uppercase tracking-wide text-red-700 dark:text-red-400">{parte.label}</h2>
					</summary>

					<div class="px-4 pb-4 space-y-2">
						{parte.nodes.map(node => (
						<div class="bg-white dark:bg-gray-900 border border-stone-200 dark:border-gray-700 rounded-lg overflow-hidden">
							{node.children.length > 0 ? (
							<details open class="group/node">
								<summary class="flex items-center gap-2 px-4 py-2.5 cursor-pointer select-none hover:bg-stone-50 dark:hover:bg-gray-800 transition list-none">
								<svg class="h-3 w-3 flex-shrink-0 text-gray-400 transition-transform group-open/node:rotate-90" fill="none" viewBox="0 0 24 24" stroke="currentColor">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
								</svg>
								<p class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide">{node.title}</p>
								</summary>

								<div class="px-3 pb-3 space-y-1">
								{node.children.map(child => (
									<div>
									{child.slug ? (
										<a
										href={`/suma-teologica/${child.slug}`}
										class="flex items-center gap-2 px-3 py-1.5 rounded-lg text-xs text-gray-600 dark:text-gray-400 hover:text-red-700 dark:hover:text-red-400 hover:bg-red-50 dark:hover:bg-red-950/20 transition"
										>
										{child.cuestion !== undefined && (
											<span class="text-[10px] font-mono text-gray-400 dark:text-gray-500 shrink-0">C.{child.cuestion}</span>
										)}
										<span class="truncate">{child.title}</span>
										</a>
									) : (
										<details class="group/child">
										<summary class="flex items-center gap-2 px-3 py-1.5 rounded-lg cursor-pointer select-none hover:bg-stone-50 dark:hover:bg-gray-800 transition list-none">
											<svg class="h-2.5 w-2.5 flex-shrink-0 text-gray-400 transition-transform group-open/child:rotate-90" fill="none" viewBox="0 0 24 24" stroke="currentColor">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
											</svg>
											<p class="text-[11px] font-semibold text-gray-400 dark:text-gray-500 uppercase tracking-wide">{child.title}</p>
										</summary>
										<div class="ml-4 mt-1 space-y-0.5">
											{child.children.map(leaf => (
											<a
												href={`/suma-teologica/${leaf.slug}`}
												class="flex items-center gap-2 px-3 py-1 rounded-lg text-xs text-gray-600 dark:text-gray-400 hover:text-red-700 dark:hover:text-red-400 hover:bg-red-50 dark:hover:bg-red-950/20 transition"
											>
												{leaf.cuestion !== undefined && (
												<span class="text-[10px] font-mono text-gray-400 dark:text-gray-500 shrink-0">C.{leaf.cuestion}</span>
												)}
												<span class="truncate">{leaf.title}</span>
											</a>
											))}
										</div>
										</details>
									)}
									</div>
								))}
								</div>
							</details>
							) : node.slug ? (
							<a
								href={`/suma-teologica/${node.slug}`}
								class="flex items-center gap-2 px-4 py-2.5 text-xs text-gray-600 dark:text-gray-400 hover:text-red-700 dark:hover:text-red-400 hover:bg-stone-50 dark:hover:bg-gray-800 transition"
							>
								{node.cuestion !== undefined && (
								<span class="text-[10px] font-mono text-gray-400 dark:text-gray-500 shrink-0">C.{node.cuestion}</span>
								)}
								<span class="truncate">{node.title}</span>
							</a>
							) : null}
						</div>
						))}
					</div>
					</details>
				</div>
				))}
			</div>

			<div class="mt-10 bg-red-50 dark:bg-red-950/20 border border-red-200 dark:border-red-900 rounded-xl p-6 text-center">
				<p class="text-red-900 dark:text-red-300 italic text-lg font-medium">
				«La razón natural sirve a la fe.»
				</p>
				<p class="text-red-600 dark:text-red-500 text-sm mt-2">— Santo Tomás de Aquino</p>
			</div>
		</div>
	)}
</SumaTeologicaLayout>
