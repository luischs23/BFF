---
import { getCollection, render } from "astro:content";
import SumaTeologicaLayout from "../../components/suma-teologica/SumaTeologicaLayout.astro";
import type { PartTree, TreeNode } from "../../components/suma-teologica/SumaTeologicaSidebar.astro";

const PARTES: Record<string, { label: string }> = {
	"parte-i": { label: "Parte I — Dios y la Creación" },
};

const FOLDER_LABELS: Record<string, string> = {
	'la-ciencia-teologica':       'La Ciencia Teológica',
	'dios':                        'Dios',
	'dios-uno':                    'Dios Uno',
	'dios-trino':                  'Dios Trino',
	'la-creacion-y-las-criaturas': 'La Creación y las Criaturas',
	'los-angeles-y-los-demonios':  'Los Ángeles y los Demonios',
	'la-creacion-del-mundo':       'La Creación del Mundo',
	'el-hombre-como-criatura':     'El Hombre como Criatura',
	'el-cosmos':                   'El Cosmos',
};

function formatFolderName(s: string): string {
	return FOLDER_LABELS[s] ?? s.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
}

function buildTree(cuestiones: Awaited<ReturnType<typeof getCollection<"suma-teologica">>>): PartTree[] {
	const parts: PartTree[] = [];

	for (const [parteKey, parteMeta] of Object.entries(PARTES)) {
		const parteCuestiones = cuestiones.filter(c => c.id.startsWith(parteKey + '/'));
		if (parteCuestiones.length === 0) continue;

		const nodeMap = new Map<string, TreeNode>();
		const roots: TreeNode[] = [];
		const sorted = parteCuestiones.sort((a, b) => a.id.localeCompare(b.id));

		for (const c of sorted) {
			const slugParts = c.id.split('/');
			for (let depth = 1; depth < slugParts.length; depth++) {
				const currentKey = slugParts.slice(0, depth + 1).join('/');
				if (!nodeMap.has(currentKey)) {
					const isLeaf = depth === slugParts.length - 1;
					const node: TreeNode = {
						slug: isLeaf ? c.id : '',
						title: isLeaf ? c.data.title : formatFolderName(slugParts[depth]),
						children: [],
					};
					nodeMap.set(currentKey, node);
					if (depth === 1) roots.push(node);
					else nodeMap.get(slugParts.slice(0, depth).join('/'))?.children.push(node);
				} else if (depth === slugParts.length - 1) {
					const node = nodeMap.get(currentKey)!;
					node.slug = c.id;
					node.title = c.data.title;
				}
			}
		}

		parts.push({ key: parteKey, label: parteMeta.label, nodes: roots });
	}

	return parts;
}

const { id } = Astro.params;
const currentSlug = Array.isArray(id) ? id.join('/') : (id ?? '');

const allCuestiones = await getCollection("suma-teologica");
const tree = buildTree(allCuestiones);

const cuestion = currentSlug
	? (allCuestiones.find(c => c.id === currentSlug) ?? null)
	: null;

const Content = cuestion ? (await render(cuestion)).Content : null;
const pageTitle = cuestion ? cuestion.data.title : "Suma Teológica";
---

<SumaTeologicaLayout title={pageTitle} currentSlug={currentSlug} tree={tree}>
	{Content && cuestion ? (
		<article class="suma-content bg-white dark:bg-gray-900 mx-2 mt-3 rounded-xl md:mx-0 md:mt-0 md:rounded-xl md:shadow-md p-4 md:p-10">
			<div class="mb-6 pb-4 border-b border-stone-200 dark:border-gray-700">
				<p class="text-xs font-semibold uppercase tracking-widest text-red-600 dark:text-red-400 mb-1">
					Cuestión {cuestion.data.cuestion} · {cuestion.data.articulos} {cuestion.data.articulos === 1 ? 'artículo' : 'artículos'}
				</p>
				<h1 class="text-2xl md:text-3xl font-bold text-gray-900 dark:text-gray-100">{pageTitle}</h1>
				<p class="text-xs text-gray-400 dark:text-gray-500 mt-1">{cuestion.data.seccion}</p>
			</div>
			<div class="prose prose-stone dark:prose-invert max-w-none">
				<Content />
			</div>
		</article>
	) : cuestion ? (
		<!-- Cuestión sin contenido aún -->
		<div class="mx-2 mt-3 md:mx-0 md:mt-0">
			<div class="bg-white dark:bg-gray-900 rounded-xl md:shadow-md p-8 md:p-12 text-center">
				<p class="text-xs font-semibold uppercase tracking-widest text-red-600 dark:text-red-400 mb-4">
					{cuestion.data.seccion}
				</p>
				<h1 class="text-2xl md:text-3xl font-bold text-gray-900 dark:text-gray-100 mb-3">{pageTitle}</h1>
				<p class="text-sm text-gray-500 dark:text-gray-400">
					Cuestión {cuestion.data.cuestion} · {cuestion.data.articulos} {cuestion.data.articulos === 1 ? 'artículo' : 'artículos'}
				</p>
				<div class="mt-8 inline-flex items-center gap-2 text-xs text-stone-400 dark:text-stone-600 bg-stone-100 dark:bg-gray-800 px-4 py-2 rounded-full">
					<svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
					</svg>
					Contenido pendiente de carga
				</div>
			</div>
		</div>
	) : (
		<!-- Página de inicio -->
		<div class="px-3 pt-4 md:px-0 md:pt-0">
			<div class="text-center mb-10">
				<div class="inline-flex items-center justify-center w-20 h-20 rounded-full overflow-hidden mb-4 shadow-lg">
					<img src="/Suma.jpg" alt="Suma Teológica" class="w-full h-full object-cover" />
				</div>
				<h1 class="text-3xl md:text-4xl font-bold text-gray-800 dark:text-gray-100 mb-3">Suma Teológica</h1>
				<p class="text-red-700 dark:text-red-400 font-semibold text-lg mb-2">Santo Tomás de Aquino</p>
				<p class="text-gray-600 dark:text-gray-300 max-w-xl mx-auto text-sm leading-relaxed">
					La obra cumbre de la escolástica medieval, estructurada en tres partes y organizada en cuestiones
					y artículos que abordan sistemáticamente toda la teología cristiana.
				</p>
			</div>

			<div class="space-y-6">
				{tree.map(parte => (
					<div class="bg-red-50 dark:bg-red-950/20 border border-red-200 dark:border-red-900 rounded-xl p-5">
						<h2 class="font-bold text-sm uppercase tracking-wide text-red-700 dark:text-red-400 mb-4">{parte.label}</h2>
						<div class="grid sm:grid-cols-2 gap-2">
							{parte.nodes.map(node => (
								<div class="bg-white dark:bg-gray-900 border border-stone-200 dark:border-gray-700 rounded-lg p-3">
									<p class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide mb-2">{node.title}</p>
									{node.children.length > 0 ? (
										<div class="space-y-1 pl-2">
											{node.children.map(child => (
												child.slug ? (
													<a
														href={`/suma-teologica/${child.slug}`}
														class="block text-xs text-gray-600 dark:text-gray-400 hover:text-red-700 dark:hover:text-red-400 transition truncate"
													>
														{child.title}
													</a>
												) : (
													<div>
														<p class="text-[11px] font-medium text-gray-400 dark:text-gray-500 uppercase tracking-wide mt-2 mb-1">{child.title}</p>
														{child.children.slice(0, 3).map(leaf => (
															<a
																href={`/suma-teologica/${leaf.slug}`}
																class="block text-xs text-gray-600 dark:text-gray-400 hover:text-red-700 dark:hover:text-red-400 transition truncate pl-2"
															>
																{leaf.title}
															</a>
														))}
														{child.children.length > 3 && (
															<p class="text-[11px] text-gray-400 dark:text-gray-600 pl-2 mt-0.5">
																+{child.children.length - 3} más…
															</p>
														)}
													</div>
												)
											))}
										</div>
									) : node.slug ? (
										<a
											href={`/suma-teologica/${node.slug}`}
											class="block text-xs text-gray-600 dark:text-gray-400 hover:text-red-700 dark:hover:text-red-400 transition"
										>
											{node.title}
										</a>
									) : null}
								</div>
							))}
						</div>
					</div>
				))}
			</div>

			<div class="mt-10 bg-red-50 dark:bg-red-950/20 border border-red-200 dark:border-red-900 rounded-xl p-6 text-center">
				<p class="text-red-900 dark:text-red-300 italic text-lg font-medium">
					«La razón natural sirve a la fe.»
				</p>
				<p class="text-red-600 dark:text-red-500 text-sm mt-2">— Santo Tomás de Aquino</p>
			</div>
		</div>
	)}
</SumaTeologicaLayout>
